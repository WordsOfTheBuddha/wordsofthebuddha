{
	"name": "suttas-basics",
	"type": "module",
	"version": "0.0.1",
	"license": "MIT",
	"scripts": {
		"watch-routes": "npx tsx --trace-deprecation src/utils/contentWatcher.mjs --watch",
		"watch:images": "node src/utils/copyContentImages.mjs --watch",
		"predev": "node src/utils/copyContentImages.mjs && npx tsx --trace-deprecation src/utils/contentWatcher.mjs && node --trace-deprecation src/utils/updateTimestamps.mjs && npx tsx src/utils/generateContentCounts.ts && npx tsx src/utils/validateCatalog.ts && npx tsx src/utils/generateCollectionReferenceIndex.ts && npx tsx src/utils/generateCollectionAvailability.ts && npx tsx src/utils/generateTopicMappings.ts && npx tsx src/utils/generateQualityMappings.ts && npx tsx src/utils/generateSimileMappings.ts && npx tsx src/utils/generatePersonMappings.ts && npx tsx src/utils/generateSearchIndex.ts && npx tsx src/utils/generateReferenceSearchIndex.ts && npx tsx src/utils/generateOfflineManifest.ts && npx tsx src/utils/generateTranslationMemory.ts && node scripts/generate-audio-status.mjs && node scripts/generate-audio-titles.mjs && node scripts/generate-playlists.mjs",
		"gen:qualities": "npx tsx src/utils/generateQualityMappings.ts",
		"gen:similes": "npx tsx src/utils/generateSimileMappings.ts",
		"gen:persons": "npx tsx src/utils/generatePersonMappings.ts",
		"gen:topics": "npx tsx src/utils/generateTopicMappings.ts",
		"gen:favicons": "node src/utils/generate-favicons.mjs",
		"thermal:svg": "tsx src/utils/thermalPrintSvg.ts",
		"analyze:content-image-colors": "tsx src/utils/analyzeContentImageSvgColors.ts",
		"gen:offline": "npx tsx src/utils/generateOfflineManifest.ts",
		"dev": "concurrently \"yarn run watch-routes\" \"yarn run watch:images\" \"node --trace-deprecation ./node_modules/.bin/astro dev --host\"",
		"prebuild": "node src/utils/copyContentImages.mjs && npx tsx --trace-deprecation src/utils/contentWatcher.mjs && node src/utils/updateTimestamps.mjs && npx tsx src/utils/generateContentCounts.ts && npx tsx src/utils/validateCatalog.ts && npx tsx src/utils/generateCollectionReferenceIndex.ts && npx tsx src/utils/generateCollectionAvailability.ts && npx tsx src/utils/generateTopicMappings.ts && npx tsx src/utils/generateQualityMappings.ts && npx tsx src/utils/generateSimileMappings.ts && npx tsx src/utils/generatePersonMappings.ts && npx tsx src/utils/generateSearchIndex.ts && npx tsx src/utils/generateReferenceSearchIndex.ts && npx tsx src/utils/generateOfflineManifest.ts && node scripts/generate-audio-status.mjs && node scripts/generate-audio-titles.mjs && node scripts/generate-playlists.mjs",
		"gen:search": "npx tsx src/utils/generateSearchIndex.ts",
		"gen:reference-search": "npx tsx src/utils/generateReferenceSearchIndex.ts",
		"bench:search": "node scripts/benchmark-search.mjs",
		"gen:catalog": "npx tsx src/utils/validateCatalog.ts && npx tsx src/utils/generateCollectionReferenceIndex.ts",
		"migrate:catalog": "node scripts/migrate-catalog-to-sujato-frontmatter.mjs",
		"validate:catalog": "npx tsx src/utils/validateCatalog.ts",
		"build": "node --trace-deprecation ./node_modules/.bin/astro build --silent",
		"postbuild": "node scripts/prune-vercel-bundle.mjs",
		"build:pwa": "astro build --config astro.config.pwa.mjs --silent",
		"prebuild:pwa": "npm run prebuild",
		"preview:pwa": "HOST=0.0.0.0 PORT=4322 node dist/server/entry.mjs",
		"dev:pwa": "astro dev --config astro.config.pwa.mjs --host",
		"test:listen": "npx tsx --test src/utils/listenDisplayWords.test.ts",
		"test:search": "cd src/search-tests && node search-test-cli.js",
		"test:search:update": "cd src/search-tests && node search-test-cli.js --update",
		"test:search:ai": "cd src/search-tests && node search-test-cli.js --ai-eval",
		"gen:icons-manifest": "npx tsx src/utils/buildIconsManifest.ts",
		"validate:icons": "npx tsx src/utils/validateIconManifest.ts",
		"gen:icons-index": "npx tsx src/utils/generateIconsIndex.ts",
		"normalize:design-icons": "npx tsx src/utils/normalizeDesignSystemIcons.ts",
		"refresh:design-icons": "npx tsx src/utils/normalizeDesignSystemIcons.ts --glob \"icons/*.svg\"",
		"voice:push": ".venv-voice/bin/python scripts/sync_audio_r2.py push",
		"voice:pull": ".venv-voice/bin/python scripts/sync_audio_r2.py pull",
		"voice:status": "node scripts/generate-audio-status.mjs",
		"voice:titles": "node scripts/generate-audio-titles.mjs",
		"voice:rerecord-impact": "python3 scripts/detect-rerecord-impact.py --rev-range HEAD --format pretty",
		"gen:playlists": "node scripts/generate-playlists.mjs",
		"import:sc": "node scripts/import-sc-bilara.mjs",
		"import:sc-structure": "node scripts/import-sc-structure.mjs",
		"voice:gen": ".venv-voice/bin/python scripts/generate_voice.py",
		"voice:edit": ".venv-voice/bin/python scripts/edit_voice.py",
		"voice:normalize": ".venv-voice/bin/python scripts/normalize_voice.py"
	},
	"dependencies": {
		"@astrojs/check": "0.9.9",
		"@astrojs/mdx": "7.0.0",
		"@astrojs/markdown-remark": "7.2.0",
		"@astrojs/tailwind": "6.0.2",
		"@astrojs/vercel": "11.0.0",
		"@aws-sdk/client-s3": "^3.750.0",
		"@sc-voice/ms-dpd": "^2.54.0",
		"@sparticuz/chromium-min": "143.0.4",
		"@vercel/analytics": "^1.4.1",
		"@vercel/speed-insights": "^1.1.0",
		"astro": "7.0.3",
		"cytoscape": "^3.33.1",
		"fast-xml-parser": "4.5.4",
		"firebase": "^11.2.0",
		"firebase-admin": "^13.0.2",
		"fuse.js": "^7.1.0",
		"gray-matter": "^4.0.3",
		"jsdom": "^26.1.0",
		"marked": "^15.0.6",
		"playwright-core": "^1.58.2",
		"rangy": "^1.3.1",
		"rehype-external-links": "^3.0.0",
		"tailwindcss": "^3.4.17",
		"tippy.js": "^6.3.7",
		"typescript": "^5.7.3"
	},
	"resolutions": {
		"shell-quote": "1.8.4",
		"protobufjs": "7.5.5"
	},
	"devDependencies": {
		"@astrojs/node": "11.0.0",
		"@resvg/resvg-js": "^2.6.2",
		"@tailwindcss/typography": "^0.5.16",
		"@types/js-yaml": "^4.0.9",
		"@types/jsdom": "^21.1.7",
		"@types/node": "^22.10.7",
		"@types/rangy": "^0.0.38",
		"concurrently": "^9.1.2",
		"glob": "^11.0.1",
		"playwright": "^1.53.2",
		"png-to-ico": "^3.0.1",
		"svg-path-bounds": "^1.0.2",
		"ts-node": "^10.9.2",
		"tsx": "^4.19.4"
	}
}
