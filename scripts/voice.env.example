# Copy to repo root .env (not committed) or export in shell.

# Path to Google Cloud service account JSON (Text-to-Speech API enabled on the project)
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Chirp 3 HD — Charon (male, en-US)
TTS_VOICE=en-US-Chirp3-HD-Charon
TTS_LANGUAGE_CODE=en-US

# Whisper model for forced alignment (stable-ts / openai-whisper)
WHISPER_MODEL=base
# Optional post-pass for repeated adjacent sentence phrases
VOICE_ENABLE_SENTENCE_REALIGN=1

# Milliseconds of silence between SSML <p> blocks: long gap after verse blocks only (default 1200)
TTS_PARAGRAPH_BREAK_MS=1200
# Prose paragraphs (including speaker / quoted lines) use this shorter gap (default 800)
TTS_CONSECUTIVE_PARAGRAPH_BREAK_MS=800

# Cloudflare R2 — audio file storage (scripts/sync_audio_r2.py)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET=dhamma-audio

# Vercel / Astro: public origin for voice files (no path segment; objects are /<slug>.opus)
# PUBLIC_AUDIO_BASE_URL=https://hear.wordsofthebuddha.org
