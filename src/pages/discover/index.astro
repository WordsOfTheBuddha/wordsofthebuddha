---
export const prerender = true;
import Layout from "../../layouts/Layout.astro";
import BottomDrawer from "../../components/BottomDrawer.astro";
import ExploreWidget from "../../components/ExploreWidget.astro";
import { siteAvailability } from "../../data/collectionAvailability";

const seoTitle = "Discover the Words of the Buddha";
const subTitle =
	`Over ${siteAvailability.unitCount.toLocaleString()} discourses, verses, sayings, passages, and utterances from ${siteAvailability.textCount.toLocaleString()} texts with parallel Pāli-English translations`;
const description = "Explore";
---

<Layout seoTitle={seoTitle} showAuth={true} showSearch={false}>
	<main class="container mx-auto px-3 sm:px-4 pt-0">
		<ExploreWidget
			mode="full"
			showProjectStatus={true}
			title={seoTitle}
			subTitle={subTitle}
			description={description}
		/>
	</main>

	<BottomDrawer />
</Layout>
