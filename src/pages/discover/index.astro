---
export const prerender = true;
import Layout from "../../layouts/Layout.astro";
import BottomDrawer from "../../components/BottomDrawer.astro";
import ExploreWidget from "../../components/ExploreWidget.astro";
import StartHere from "../../components/StartHere.astro";
import CollectionCards from "../../components/CollectionCards.astro";

const seoTitle = "Discover the Words of the Buddha";
---

<Layout seoTitle={seoTitle} showAuth={true} showSearch={false}>
	<main class="container mx-auto px-3 sm:px-4 pt-0">
		<section class="max-w-4xl mx-auto px-1 pt-10 pb-4 text-center">
			<h1
				class="text-3xl sm:text-4xl font-bold tracking-tight mb-3 text-gradient-accent"
				style="font-family:'Spectral', serif;"
			>
				Discover the Teachings
			</h1>
			<p class="text-lg max-w-2xl mx-auto mb-0" style="color:var(--text-muted);">
				Read parallel Pāli and English texts — browse collections, topics, persons, and similes.
			</p>
		</section>

		<StartHere />

		<section class="max-w-4xl mx-auto px-4 mb-14">
			<h2 class="text-2xl font-semibold mb-2">Explore the Collections</h2>
			<p class="mb-4 text-sm" style="color:var(--text-muted);">
				Browse the major texts of the Pāli Canon, with parallel Pāli and English on every page.
			</p>
			<CollectionCards />
		</section>

		<section class="max-w-4xl mx-auto px-4 mb-14">
			<h2 class="text-2xl font-semibold mb-2">Topics, Persons & Similes</h2>
			<p class="mb-4 text-sm" style="color:var(--text-muted);">
				Browse an A–Z index or search across the site.
			</p>
			<ExploreWidget mode="full" title="" />
		</section>
	</main>

	<BottomDrawer />
</Layout>
