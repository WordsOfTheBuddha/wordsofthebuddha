---
// Prerendered canonical discourse pages for offline/PWA and fast static delivery.
// Native English translations only; reference fallbacks are SSR via middleware → /discourse-ssr/:id.
export const prerender = true;
import { getEnglishEntry, getPaliEntry } from "../utils/getContentEntry";
import Layout from "../layouts/Layout.astro";
import MDContent from "../components/MDContent.astro";
import { routes } from "../utils/routes";
import { parseContent, createCombinedMarkdown } from "../utils/contentParser";
import { getLastModified } from "../utils/getLastModified";
import { findContentImages } from "../utils/contentImage";

export async function getStaticPaths() {
	return routes.map((discourse) => ({ params: { discourse } }));
}

const { discourse: id } = Astro.params as { discourse?: string };

if (!id) {
	return new Response(null, { status: 404 });
}

const contentItem = await getEnglishEntry(id);
if (!contentItem) {
	return new Response(null, { status: 404 });
}

let paliContent: { body: string } = { body: "" };
const paliEntry = await getPaliEntry(id);
if (paliEntry) paliContent = paliEntry;

const pairs = await parseContent(paliContent, contentItem);
const interleavedContent = createCombinedMarkdown(pairs, true, "interleaved");
const splitContent = createCombinedMarkdown(pairs, true, "split");

const mainContent =
	typeof interleavedContent === "string" ? interleavedContent : "";
const splitEnglish =
	typeof splitContent !== "string" ? splitContent.english : undefined;
const splitPali =
	typeof splitContent !== "string" ? splitContent.pali : undefined;

const filePath = contentItem.filePath || "";
const lastUpdated = getLastModified(filePath);
const fpParts = (contentItem.filePath ?? "").split("/");
const folder = fpParts[fpParts.length - 2] || "";
const fp = folder ? `${folder}/${id}` : id;

const currentIndex = routes.findIndex((r) => r === id);
const next =
	currentIndex + 1 < routes.length
		? await getEnglishEntry(routes[currentIndex + 1])
		: null;
const prev =
	currentIndex - 1 >= 0
		? await getEnglishEntry(routes[currentIndex - 1])
		: null;

const contentImages = findContentImages(
	id,
	{
		image: contentItem.data.image,
		imageCaption: contentItem.data.imageCaption,
	},
	contentItem.data.title,
);
const contentImage = contentImages.length > 0 ? contentImages : null;

const suttaProps = {
	fp,
	title: contentItem.data.title,
	description: contentItem.data.description,
	qualities: contentItem.data.qualities?.split(",").map((t: string) => t.trim()),
	prev,
	next,
	id,
	showReadLater: true,
	showSave: true,
	showRead: true,
	lastUpdated,
	showAuth: true,
	showPali: true,
	paragraphRequest: null,
	discourseRange: null,
	commentary: contentItem.data.commentary,
	contentImage,
};
---

<Layout {...suttaProps}>
	<MDContent
		content={mainContent}
		splitEnglish={splitEnglish}
		splitPali={splitPali}
	/>

	<!-- Paragraph ranges (e.g. /sn1.1.1-2) are SSR at src/pages/[...id].astro. -->
</Layout>
