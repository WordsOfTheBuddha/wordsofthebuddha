---
import Layout from "./Layout.astro";
import PostCard from "../components/PostCard.astro";
import { performSearch, type SearchResult } from "../service/search/search";
import type { DirectoryStructure } from "../types/directory";
import { directoryStructureWithCounts } from "../data/directoryStructureWithCounts";
import ScrollToTop from "../components/ScrollToTop.astro";
import CollectionNavigation from "../components/CollectionNavigation.astro";
import CollectionExportButton from "../components/CollectionExportButton.astro";
import CollectionPdfExportModal from "../components/CollectionPdfExportModal.astro";
import { getCollectionPdfPreviewMeta } from "../utils/collectionPdfPreviewMeta";
import {
	collectionExportHasSvgViz,
	collectionExportTextFileCount,
} from "../utils/collectionPdfExportScope";
import { buildPdfExportSelectionTree } from "../utils/collectionPdfExportTree";
import { getReferencePostsForCollection } from "../utils/referencePostsForPage";

import {
	formatVaggaDisplayTitle,
	groupDiscoursesByVaggaSection,
	groupDiscoursesByChildBooksAndVagga,
	usesBookScopedVaggaGrouping,
} from "../utils/vaggaSections";

interface Props {
	title: string;
	description: string;
	searchPattern: string;
	collection?: boolean;
	children?: Record<string, DirectoryStructure>;
	vaggaSections?: Record<string, DirectoryStructure>;
	collectionSlug?: string;
}

const {
	title,
	description,
	searchPattern,
	collection = false,
	children,
	vaggaSections,
	collectionSlug,
} = Astro.props;

const pagePosts: SearchResult[] = await performSearch(searchPattern, {
	highlight: true,
});

const pdfPreviewMeta = collectionSlug
	? getCollectionPdfPreviewMeta(collectionSlug)
	: null;

const previewHasSvgViz = collectionSlug
	? await collectionExportHasSvgViz(collectionSlug)
	: false;

const previewTextFileCount = collectionSlug
	? await collectionExportTextFileCount(collectionSlug)
	: 0;

const pdfExportSelectionTree = collectionSlug
	? await buildPdfExportSelectionTree(collectionSlug)
	: null;

const hasChildCollections = children && Object.keys(children).length > 0;
const hasVaggaSections =
	vaggaSections && Object.keys(vaggaSections).length > 0;
const bookScopedDiscourses =
	hasChildCollections &&
	hasVaggaSections &&
	usesBookScopedVaggaGrouping(vaggaSections, children) &&
	children
		? groupDiscoursesByChildBooksAndVagga(pagePosts, children)
		: null;
// SN range parents (e.g. /sn12-21) already show the page description above the filter.
const suppressBookDescriptionsInDiscourses =
	!!bookScopedDiscourses &&
	hasChildCollections &&
	!!collectionSlug &&
	/^sn\d+-\d+$/.test(collectionSlug);
const sectionedDiscourses =
	!bookScopedDiscourses && hasVaggaSections
		? groupDiscoursesByVaggaSection(pagePosts, vaggaSections)
		: null;
// Toggle only for pages with child sub-collections (e.g. /mn, /an), not vagga-only leaves.
const hasChildren = hasChildCollections;
// Inline script below applies hash before first paint on parent collection pages.
const defaultShowCollections = hasChildren;

const enSlugsOnPage = new Set(pagePosts.map((post) => post.slug));
const referencePostsForCollection = collectionSlug
	? getReferencePostsForCollection(collectionSlug, enSlugsOnPage)
	: [];
const hasReferenceOnlyDiscourses = referencePostsForCollection.length > 0;
const referencePostsData = referencePostsForCollection.map(
	({ slug, title, description }) => ({
		slug,
		title,
		description,
	}),
);
const referencePostsJson = JSON.stringify(referencePostsData);

/** Runs in <head> before body paint to avoid Collections→Discourses flash when URL has a hash. */
const collectionViewBootstrapScript = `(function () {
  if (window.location.hash) {
    document.documentElement.setAttribute("data-collection-view", "discourses");
  }
})();`;

// Dev-time debug: log render context (collection view vs discourses view)
if (import.meta.env?.DEV) {
	console.log("[CollectionLayout] rendering", {
		path: Astro.url.pathname,
		hasChildren,
		searchPattern,
		posts: pagePosts.length,
		childCollections: hasChildren ? Object.keys(children || {}).length : 0,
		defaultShowCollections,
	});
	if (collectionSlug && hasReferenceOnlyDiscourses) {
		console.log("[CollectionLayout:ref] build", {
			collectionSlug,
			referenceCount: referencePostsData.length,
			enOnPage: enSlugsOnPage.size,
		});
	}
}

// Function to find availability counts for a specific slug
function findDirectoryNodeInCounts(slug: string) {
	if (directoryStructureWithCounts[slug]) {
		return directoryStructureWithCounts[slug];
	}
	for (const top of Object.values(directoryStructureWithCounts)) {
		if (top.children?.[slug]) {
			return top.children[slug];
		}
	}
	return undefined;
}

function getAvailabilityCounts(slug: string): {
	readableCount: number;
	translatedCount: number;
} {
	const empty = { readableCount: 0, translatedCount: 0 };
	const currentPath = Astro.url.pathname.replace(/\/$/, "");
	const pathParts = currentPath.split("/").filter(Boolean);

	const fromNode = (
		node: DirectoryStructure | undefined,
	): { readableCount: number; translatedCount: number } | null => {
		if (!node) return null;
		if (
			node.readableCount !== undefined ||
			node.translatedCount !== undefined
		) {
			return {
				readableCount: node.readableCount ?? node.contentCount ?? 0,
				translatedCount:
					node.translatedCount ?? node.contentCount ?? 0,
			};
		}
		if (node.contentCount !== undefined) {
			return {
				readableCount: node.contentCount,
				translatedCount: node.contentCount,
			};
		}
		return null;
	};

	const top = fromNode(directoryStructureWithCounts[slug]);
	if (top) return top;

	if (pathParts.length === 1) {
		const parentKey = Object.keys(directoryStructureWithCounts).find(
			(key) =>
				directoryStructureWithCounts[key]?.children?.[pathParts[0]],
		);

		if (parentKey) {
			const currentPathCollection =
				directoryStructureWithCounts[parentKey]?.children?.[
					pathParts[0]
				];
			const nested = fromNode(
				currentPathCollection?.children?.[slug],
			);
			if (nested) return nested;
		}
	}

	if (
		pathParts.length === 1 &&
		directoryStructureWithCounts[pathParts[0]]?.children
	) {
		const parent = directoryStructureWithCounts[pathParts[0]];
		const child = fromNode(parent.children?.[slug]);
		if (child) return child;
	}

	if (collectionSlug) {
		const bookNode = findDirectoryNodeInCounts(collectionSlug);
		const child = fromNode(bookNode?.children?.[slug]);
		if (child) return child;
	}

	if (children) {
		const child = fromNode((children as Record<string, DirectoryStructure>)[slug]);
		if (child) return child;
	}

	return empty;
}
---

<Layout title={title} description={description} showAuth={true}>
	{
		hasChildren && (
			<script slot="head" is:inline set:html={collectionViewBootstrapScript} />
		)
	}
	{
		hasChildren && (
			<style slot="head" is:global>
				{`html[data-collection-view="discourses"] #collections-grid {
	display: none !important;
}
html[data-collection-view="discourses"] #discourses-panel.hidden {
	display: contents !important;
}
html[data-collection-view="discourses"] #filter-wrap.hidden {
	display: flex !important;
}
html[data-collection-view="discourses"] #toggle-ref.hidden {
	display: inline-flex !important;
}
html[data-collection-view="discourses"] #view-collections {
	background-color: transparent !important;
	color: var(--text-muted) !important;
}
html[data-collection-view="discourses"] #view-discourses {
	background-color: var(--primary-color) !important;
	color: white !important;
}`}
			</style>
		)
	}
	<main class="container">
		<div
			class:list={[
				"collection-chrome print:hidden",
				hasChildren
					? "collection-chrome--parent mb-6"
					: "collection-chrome--leaf mb-4",
			]}
		>
			{
				hasChildren && (
					<div class="collection-chrome__toggle inline-flex w-fit shrink-0 items-center rounded-full border border-[var(--border-color)] bg-[var(--surface-paper)] p-1">
						<button
							type="button"
							id="view-collections"
							class={[
								"px-4 py-1 text-sm rounded-full transition-colors",
								defaultShowCollections
									? "bg-primary text-white dark:text-gray-100"
									: "text-[var(--text-muted)] hover:text-[var(--text-color)]",
							].join(" ")}
						>
							Collections
						</button>
						<button
							type="button"
							id="view-discourses"
							class={[
								"px-4 py-1 text-sm rounded-full transition-colors",
								!defaultShowCollections
									? "bg-primary text-white dark:text-gray-100"
									: "text-[var(--text-muted)] hover:text-[var(--text-color)]",
							].join(" ")}
						>
							Discourses
						</button>
					</div>
				)
			}
			{
				collectionSlug && (
					<div class="collection-chrome__print collection-chrome__print--mobile shrink-0 sm:hidden">
						<CollectionExportButton collectionSlug={collectionSlug} />
					</div>
				)
			}
			{
				collectionSlug && (
					<div class="collection-chrome__print collection-chrome__print--desktop hidden shrink-0 sm:block">
						<CollectionExportButton collectionSlug={collectionSlug} />
					</div>
				)
			}
			<div
				id="discourses-panel"
				class:list={[
					"collection-chrome__discourses",
					hasChildren && defaultShowCollections ? "hidden" : "",
				]}
			>
				<div
					id="filter-wrap"
					class:list={[
						"filter-toolbar not-prose w-full min-w-0",
						hasChildren && defaultShowCollections ? "hidden" : "",
					]}
				>
					<input
						type="text"
						id="client-filter"
						class="filter-toolbar-input"
						placeholder="Filter discourses..."
					/>
					{
						hasReferenceOnlyDiscourses && (
							<button
								type="button"
								id="toggle-ref"
								aria-pressed="false"
								class:list={[
									"toggle-ref filter-toolbar-btn",
									hasChildren && defaultShowCollections
										? "hidden"
										: "",
								]}
								title="Include reference-only discourses (Sujato translation)"
							>
								<span class="md:hidden">Ref</span>
								<span class="hidden md:inline">See Refs</span>
							</button>
						)
					}
				</div>
				<div
					id="discourses-grid"
					class={[
						bookScopedDiscourses || sectionedDiscourses
							? "space-y-8"
							: "posts-grid",
					].join(" ")}
					data-collection-slug={collectionSlug ?? ""}
				>
				{
					bookScopedDiscourses
						? bookScopedDiscourses.map((book) => {
								const bookHasPosts = book.sections.some(
									(section) => section.posts.length > 0,
								);
								const hasVaggaStructure = book.sections.some(
									(section) => section.slug,
								);
								return (
								<div
									class:list={[
										"book-section col-span-full space-y-6",
										!bookHasPosts && !hasVaggaStructure && "hidden",
									]}
									id={book.bookSlug}
								>
									<div class="border-b border-[var(--border-color)] pb-2">
										<h2 class="text-xl font-semibold text-[var(--text-color)]">
											{book.bookData.title}
										</h2>
										{
											!suppressBookDescriptionsInDiscourses &&
												book.bookData.description && (
													<p class="mt-1 text-sm text-[var(--text-muted)]">
														{book.bookData.description}
													</p>
												)
										}
									</div>
									<div class="space-y-8">
										{book.sections.map((section) => (
											<div
												class:list={[
													section.slug
														? "vagga-section col-span-full"
														: "book-flat-section col-span-full",
													section.slug &&
														section.posts.length === 0 &&
														"hidden",
												]}
												id={section.slug || undefined}
											>
												{
													section.slug && (
														<div class="vagga-section-header mb-4 mt-2 border-b border-[var(--border-color)] pb-2">
															<h3 class="text-lg font-semibold text-[var(--text-color)]">
																{formatVaggaDisplayTitle(
																	section.data.title,
																)}
															</h3>
															{
																section.data
																	.description && (
																	<p class="mt-1 text-sm text-[var(--text-muted)]">
																		{
																			section
																				.data
																				.description
																		}
																	</p>
																)
															}
														</div>
													)
												}
												<div class="posts-grid">
													{section.posts.map((post) => (
														<PostCard
															title={post.title}
															description={
																post.description
															}
															id={post.slug}
															clamp={5}
														/>
													))}
												</div>
											</div>
										))}
									</div>
								</div>
								);
							})
						: sectionedDiscourses
						? sectionedDiscourses.map((section) => (
								<div
									class:list={[
										section.slug
											? "vagga-section col-span-full"
											: "col-span-full",
										section.slug &&
											section.posts.length === 0 &&
											"hidden",
									]}
									id={section.slug || undefined}
								>
									{
										section.slug && (
											<div class="vagga-section-header mb-4 mt-2 border-b border-[var(--border-color)] pb-2">
												<h2 class="text-lg font-semibold text-[var(--text-color)]">
													{formatVaggaDisplayTitle(
														section.data.title,
													)}
												</h2>
												{
													section.data.description && (
														<p class="mt-1 text-sm text-[var(--text-muted)]">
															{section.data.description}
														</p>
													)
												}
											</div>
										)
									}
									<div class="posts-grid">
										{section.posts.map((post) => (
											<PostCard
												title={post.title}
												description={post.description}
												id={post.slug}
												clamp={5}
											/>
										))}
									</div>
								</div>
							))
						: pagePosts.map((post) => (
								<PostCard
									title={post.title}
									description={post.description}
									id={post.slug}
									clamp={5}
								/>
							))
				}
					<div id="reference-cards-mount" />
				</div>
			</div>
		</div>

		{/* Render both; client toggles on parent collection pages */}
		{
			hasChildren && (
				<div
					id="collections-grid"
					class={[
						"posts-grid",
						defaultShowCollections ? "" : "hidden",
					].join(" ")}
				>
					{(
						Object.entries(children || {}) as [
							string,
							DirectoryStructure,
						][]
					).map(([slug, data]) => {
						const { readableCount } = getAvailabilityCounts(slug);
						return (
							<PostCard
								title={data.title}
								description={data.description || ""}
								id={slug}
								clamp={5}
								count={readableCount}
							/>
						);
					})}
				</div>
			)
		}

		{
			hasReferenceOnlyDiscourses && (
				<script
					id="reference-posts-data"
					type="application/json"
					set:html={referencePostsJson}
				/>
			)
		}

		{collectionSlug && <CollectionNavigation collection={collectionSlug} />}
	</main>

	{
		collectionSlug && (
			<CollectionPdfExportModal
				collectionSlug={collectionSlug}
				previewTitle={pdfPreviewMeta?.title ?? title}
				previewScopeSummary={
					pdfPreviewMeta?.scopeSummary ??
					`This export includes ${pagePosts.length} discourses.`
				}
				previewTotalTextFiles={previewTextFileCount}
				previewHasChapters={pdfPreviewMeta?.hasChapters ?? false}
				previewChapters={pdfPreviewMeta?.chapters ?? []}
				previewHasSvgViz={previewHasSvgViz}
				exportSelectionTree={pdfExportSelectionTree}
			/>
		)
	}

	<ScrollToTop />

	<style>
		.bg-primary {
			background-color: var(--primary-color);
		}
		.active-tab {
			background-color: var(--primary-color);
			color: white;
		}
		.collection-chrome {
			display: grid;
			column-gap: 0.75rem;
			row-gap: 0.75rem;
			align-items: center;
		}
		.collection-chrome--leaf {
			grid-template-columns: minmax(0, 1fr) auto;
			grid-template-areas:
				"print print"
				"filter filter";
		}
		.collection-chrome--parent {
			grid-template-columns: minmax(0, 1fr) auto;
			grid-template-areas:
				"toggle print"
				"filter filter";
		}
		.collection-chrome__toggle {
			grid-area: toggle;
		}
		.collection-chrome__print {
			grid-area: print;
			justify-self: end;
		}
		.collection-chrome__discourses:not(.hidden) {
			display: contents;
		}
		#filter-wrap {
			grid-area: filter;
		}
		#discourses-grid {
			grid-column: 1 / -1;
		}
		@media (min-width: 768px) {
			.collection-chrome--leaf {
				grid-template-areas: "filter print";
			}
		}
		@media (min-width: 1024px) {
			.collection-chrome--parent {
				grid-template-columns: auto minmax(0, 1fr) auto;
				grid-template-areas: "toggle filter print";
			}
		}
		#filter-wrap.hidden {
			display: none !important;
		}
		#toggle-ref.hidden {
			display: none !important;
		}
		.filter-toolbar-btn:not(.hidden) {
			display: inline-flex;
			align-items: center;
			flex-shrink: 0;
			font-size: 0.8rem;
			font-family: inherit;
			line-height: 1.25;
			color: var(--text-muted, #666);
			background: transparent;
			border: none;
			border-radius: 9999px;
			padding: 0.35rem 0.75rem;
			cursor: pointer;
			transition:
				color 0.15s,
				background 0.15s;
			white-space: nowrap;
		}
		.filter-toolbar-btn:hover:not(.filter-toolbar-btn--active) {
			color: var(--text-color);
			background: color-mix(
				in srgb,
				var(--surface-elevated, #f5f3ef) 80%,
				transparent
			);
		}
		:global(#toggle-ref.filter-toolbar-btn--active) {
			color: white !important;
			font-weight: 500;
			background: var(--primary-color) !important;
		}
		:global(#toggle-ref.filter-toolbar-btn--active:hover) {
			color: white !important;
			background: var(--link-hover-color) !important;
		}
		html.dark :global(#toggle-ref.filter-toolbar-btn--active) {
			color: var(--secondary-color) !important;
			background: color-mix(
				in srgb,
				var(--secondary-color) 14%,
				transparent
			) !important;
		}
		html.dark :global(#toggle-ref.filter-toolbar-btn--active:hover) {
			color: var(--secondary-color) !important;
			background: color-mix(
				in srgb,
				var(--secondary-color) 22%,
				transparent
			) !important;
		}
		.filter-toolbar:not(.hidden) {
			display: flex;
			align-items: center;
			align-self: flex-start;
			min-width: 0;
			width: 100%;
			position: sticky;
			top: 0;
			z-index: 20;
			margin-bottom: 1rem;
			padding: 0.125rem 0.35rem 0.125rem 0.85rem;
			border: 1px solid var(--border-color, rgba(44, 44, 44, 0.2));
			border-radius: 9999px;
			background: var(--surface-paper);
		}
		@media (min-width: 768px) {
			.collection-chrome--leaf .filter-toolbar:not(.hidden) {
				margin-bottom: 0;
			}
		}
		@media (min-width: 1024px) {
			.collection-chrome--parent .filter-toolbar:not(.hidden) {
				margin-bottom: 0;
			}
		}
		.filter-toolbar-input {
			flex: 1;
			min-width: 0;
			width: 100%;
			padding: 0.45rem 0.5rem 0.45rem 0;
			font-size: 0.875rem;
			font-family: inherit;
			color: var(--text-color);
			background: transparent;
			border: none;
			outline: none;
		}
		.filter-toolbar-input::placeholder {
			color: var(--text-muted, #666);
		}
		.filter-toolbar-input:focus {
			outline: none;
		}
	</style>

	<script>
	import { initReferenceDiscourseCards } from "../utils/referenceDiscourseCardsClient";
	import { collectionLayoutDebugLog } from "../utils/collectionLayoutDebug";

	let collectionsGrid;
	let discoursesGrid;
	let discoursesPanel;
	let filterWrap;
	let btnCollections;
	let btnDiscourses;
	let hasChildren;
	let syncRefToggleVisibility;
	let refreshVaggaScrollSpy;

	function setTabActive(btn, active) {
		btn.classList.toggle("bg-primary", active);
		btn.classList.toggle("text-white", active);
		btn.classList.toggle("dark:text-gray-100", active);
		btn.classList.toggle("text-[var(--text-muted)]", !active);
		btn.classList.toggle("hover:text-[var(--text-color)]", !active);
	}

	function scrollToHash() {
		const hash = window.location.hash;
		if (!hash) return;
		const id = decodeURIComponent(hash.slice(1));
		const target = document.getElementById(id);
		target?.scrollIntoView({ behavior: "smooth", block: "start" });
	}

	function updateViewUrl(mode) {
		const url = new URL(window.location.href);
		url.searchParams.delete("view");
		if (mode === "collections") {
			url.hash = "";
		}
		window.history.replaceState(
			{},
			"",
			`${url.pathname}${url.search}${url.hash}`,
		);
	}

	function resolveInitialViewMode() {
		const params = new URLSearchParams(window.location.search);
		const view = params.get("view");
		if (view === "discourses" || window.location.hash) return "discourses";
		return "collections";
	}

	function syncCollectionViewAttribute(mode) {
		if (!hasChildren) return;
		if (mode === "discourses") {
			document.documentElement.setAttribute(
				"data-collection-view",
				"discourses",
			);
		} else {
			document.documentElement.removeAttribute("data-collection-view");
		}
	}

	function setView(mode) {
		const showCollections = hasChildren && mode !== "discourses";
		const showDiscourses = !showCollections;
		syncCollectionViewAttribute(mode);
		if (collectionsGrid)
			collectionsGrid.classList.toggle("hidden", !showCollections);
		if (discoursesPanel)
			discoursesPanel.classList.toggle("hidden", showCollections);
		if (filterWrap)
			filterWrap.classList.toggle("hidden", showCollections);
		if (btnCollections && btnDiscourses) {
			setTabActive(btnCollections, showCollections);
			setTabActive(btnDiscourses, !showCollections);
		}
		syncRefToggleVisibility?.(showDiscourses);
		if (showDiscourses) {
			requestAnimationFrame(() => refreshVaggaScrollSpy?.());
		}
	}

	function getActiveFilter() {
		const input = document.getElementById("client-filter");
		return normalizeFilterText(input?.value);
	}

	function normalizeFilterText(value) {
		return (
			value
				?.toLowerCase()
				.normalize("NFD")
				.replace(/[\u0300-\u036f]/g, "") || ""
		);
	}

	function postMatchesFilter(post, filter) {
		const aTag = post.querySelector("a");
		const hrefValue = aTag?.getAttribute("href")?.toLowerCase() || "";
		const content = normalizeFilterText(post.textContent);
		const combinedContent = `${hrefValue} ${content}`;
		return !filter || combinedContent.includes(filter);
	}

	function applyFilter(filter) {
		const books = discoursesGrid?.querySelectorAll(".book-section");
		if (books?.length) {
			books.forEach((book) => {
				const bookHeader = book.querySelector(":scope > div > h2");
				const bookDescription = book.querySelector(":scope > div > p");
				const bookHeaderText = normalizeFilterText(
					bookHeader?.textContent,
				);
				const bookDescriptionText = normalizeFilterText(
					bookDescription?.textContent,
				);
				const bookMatches =
					!!filter &&
					(bookHeaderText.includes(filter) ||
						bookDescriptionText.includes(filter));

				const sections = book.querySelectorAll(".vagga-section");
				const flatSections = book.querySelectorAll(".book-flat-section");
				let anyBookContentVisible = bookMatches;
				if (sections.length) {
					sections.forEach((section) => {
						const header = section.querySelector("h3");
						const description = section.querySelector("p");
						const headerText = normalizeFilterText(
							header?.textContent,
						);
						const descriptionText = normalizeFilterText(
							description?.textContent,
						);
						const sectionMatches =
							!!filter &&
							(headerText.includes(filter) ||
								descriptionText.includes(filter));

						const posts = section.querySelectorAll(".post-item");
						let anyPostVisible = false;
						posts.forEach((post) => {
							const visible =
								bookMatches ||
								sectionMatches ||
								postMatchesFilter(post, filter);
							post.classList.toggle("hidden", !visible);
							if (visible) anyPostVisible = true;
						});

						section.classList.toggle(
							"hidden",
							!!filter &&
								!bookMatches &&
								!sectionMatches &&
								!anyPostVisible,
						);
						if (!section.classList.contains("hidden")) {
							anyBookContentVisible = true;
						}
					});
				} else if (flatSections.length) {
					flatSections.forEach((section) => {
						const posts = section.querySelectorAll(".post-item");
						let anyPostVisible = false;
						posts.forEach((post) => {
							const visible =
								bookMatches || postMatchesFilter(post, filter);
							post.classList.toggle("hidden", !visible);
							if (visible) anyPostVisible = true;
						});
						section.classList.toggle(
							"hidden",
							!!filter && !bookMatches && !anyPostVisible,
						);
						if (!section.classList.contains("hidden")) {
							anyBookContentVisible = true;
						}
					});
				} else {
					const posts = book.querySelectorAll(".post-item");
					posts.forEach((post) => {
						const visible =
							bookMatches || postMatchesFilter(post, filter);
						post.classList.toggle("hidden", !visible);
						if (visible) anyBookContentVisible = true;
					});
				}

				book.classList.toggle(
					"hidden",
					!!filter && !anyBookContentVisible,
				);
			});
			return;
		}

		const sections = discoursesGrid?.querySelectorAll(".vagga-section");
		if (sections?.length) {
			sections.forEach((section) => {
				const header = section.querySelector("h2");
				const description = section.querySelector("p");
				const headerText = normalizeFilterText(header?.textContent);
				const descriptionText = normalizeFilterText(
					description?.textContent,
				);
				const sectionMatches =
					!!filter &&
					(headerText.includes(filter) ||
						descriptionText.includes(filter));

				const posts = section.querySelectorAll(".post-item");
				let anyPostVisible = false;
				posts.forEach((post) => {
					const visible =
						sectionMatches || postMatchesFilter(post, filter);
					post.classList.toggle("hidden", !visible);
					if (visible) anyPostVisible = true;
				});

				section.classList.toggle(
					"hidden",
					!!filter && !sectionMatches && !anyPostVisible,
				);
			});
			return;
		}

		const posts = discoursesGrid?.querySelectorAll(".post-item");
		posts?.forEach((post) => {
			post.classList.toggle("hidden", !postMatchesFilter(post, filter));
		});
	}

	function bindCollectionLayoutElements() {
		hasChildren = !!document.getElementById("collections-grid");
		collectionsGrid = document.getElementById("collections-grid");
		discoursesGrid = document.getElementById("discourses-grid");
		discoursesPanel = document.getElementById("discourses-panel");
		filterWrap = document.getElementById("filter-wrap");
		btnCollections = document.getElementById("view-collections");
		btnDiscourses = document.getElementById("view-discourses");
	}

	function initVaggaScrollSpy() {
		let sections = [];
		let scrollRaf = 0;
		let stickyDebugRaf = 0;

		const collectSections = () => [
			...(discoursesGrid?.querySelectorAll(".vagga-section[id]") ?? []),
		];

		const scrollAnchorY = () => {
			const wrap = filterWrap ?? document.getElementById("filter-wrap");
			const fallback = 72;
			if (!wrap || wrap.classList.contains("hidden")) return fallback;

			const rect = wrap.getBoundingClientRect();
			// Sticky filter stays near the top; use its bottom as the section anchor.
			if (rect.bottom > 0) {
				return rect.bottom + 8;
			}
			return fallback;
		};

		const setActiveSection = (active) => {
			for (const section of sections) {
				section.classList.toggle(
					"vagga-section--in-view",
					section === active,
				);
			}
		};

		const pickActiveSection = () => {
			if (discoursesPanel?.classList.contains("hidden")) {
				setActiveSection(null);
				collectionLayoutDebugLog("scroll-spy: panel hidden");
				return;
			}

			const visible = sections.filter(
				(section) => !section.classList.contains("hidden"),
			);
			if (!visible.length) {
				setActiveSection(null);
				collectionLayoutDebugLog("scroll-spy: no visible sections", {
					sectionsFound: sections.length,
				});
				return;
			}

			const anchor = scrollAnchorY();
			let active = visible[0];
			for (const section of visible) {
				const header = section.querySelector(".vagga-section-header");
				const top = (header ?? section).getBoundingClientRect().top;
				if (top <= anchor) active = section;
			}
			setActiveSection(active);
			collectionLayoutDebugLog("scroll-spy", {
				anchorY: anchor,
				activeSectionId: active?.id ?? null,
				sectionsFound: sections.length,
				visibleSections: visible.length,
			});
		};

		const logStickyOnScroll = () => {
			if (stickyDebugRaf) return;
			stickyDebugRaf = requestAnimationFrame(() => {
				stickyDebugRaf = 0;
				const wrap = filterWrap ?? document.getElementById("filter-wrap");
				if (!wrap) return;
				const rect = wrap.getBoundingClientRect();
				collectionLayoutDebugLog("sticky filter", {
					top: Math.round(rect.top),
					bottom: Math.round(rect.bottom),
					position: getComputedStyle(wrap).position,
					isHidden: wrap.classList.contains("hidden"),
				});
			});
		};

		const schedulePickActiveSection = () => {
			if (scrollRaf) return;
			scrollRaf = requestAnimationFrame(() => {
				scrollRaf = 0;
				pickActiveSection();
				logStickyOnScroll();
			});
		};

		// Viewport scroll fires on window / <html>, not on document (no bubbling).
		window.addEventListener("scroll", schedulePickActiveSection, {
			passive: true,
		});

		window.addEventListener(
			"resize",
			() => {
				sections = collectSections();
				schedulePickActiveSection();
			},
			{ passive: true },
		);

		refreshVaggaScrollSpy = () => {
			bindCollectionLayoutElements();
			sections = collectSections();
			pickActiveSection();
		};

		refreshVaggaScrollSpy();
	}

	function initCollectionLayout() {
		bindCollectionLayoutElements();

		collectionLayoutDebugLog("init", {
			path: window.location.pathname,
			search: window.location.search,
			hasChildren,
		});

		const refCards = initReferenceDiscourseCards({
			getActiveFilter,
			applyFilter,
			onAfterSync: () => refreshVaggaScrollSpy?.(),
		});
		syncRefToggleVisibility = refCards?.syncRefToggleVisibility;

		const mode = resolveInitialViewMode();
		if (hasChildren) {
			setView(mode);
		} else {
			syncRefToggleVisibility?.(true);
		}

		initVaggaScrollSpy();

		if (new URL(window.location.href).searchParams.has("view")) {
			updateViewUrl(mode);
		}

		if (window.location.hash) {
			requestAnimationFrame(() => scrollToHash());
		}

		btnCollections?.addEventListener("click", () => {
			setView("collections");
			updateViewUrl("collections");
		});
		btnDiscourses?.addEventListener("click", () => {
			setView("discourses");
			updateViewUrl("discourses");
			if (window.location.hash) {
				requestAnimationFrame(() => scrollToHash());
			}
		});

		const input = document.getElementById("client-filter");
		input?.addEventListener("input", (e) => {
			applyFilter(normalizeFilterText(e.target.value));
			refreshVaggaScrollSpy?.();
		});
	}

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", initCollectionLayout);
	} else {
		initCollectionLayout();
	}
	</script>
</Layout>
