---
/**
 * Listen-mode UI shell. Owns the persistent `<audio>` element and transport.
 * Track transitions inside listen mode update src + DOM + URL via
 * `history.replaceState` — no full page navigation.
 *
 * Discourse text is rendered at *runtime* from the manifest's paragraph words,
 * keeping this surface independent of the MDX rendering pipeline (no Pāli,
 * no glossary tooltips). v1 prototype: paragraph-level highlight only.
 */
interface Props {
	slug: string;
	displayId: string;
	title: string;
	description?: string;
	nextSlug: string | null;
	nextTitle: string | null;
	nextDescription?: string | null;
	nextDisplayId: string | null;
	prevSlug: string | null;
	prevTitle: string | null;
	prevDescription?: string | null;
	prevDisplayId: string | null;
}
const props = Astro.props;
const initialDataJson = JSON.stringify({
	slug: props.slug,
	displayId: props.displayId,
	title: props.title,
	description: props.description ?? null,
	nextSlug: props.nextSlug,
	nextTitle: props.nextTitle,
	nextDescription: props.nextDescription ?? null,
	nextDisplayId: props.nextDisplayId,
	prevSlug: props.prevSlug,
	prevTitle: props.prevTitle,
	prevDescription: props.prevDescription ?? null,
	prevDisplayId: props.prevDisplayId,
});
---

<main id="listen-root" class="listen-root" aria-label="Listen mode">
	<header class="listen-header">
		<div class="listen-meta">
			<span class="listen-display-id" id="listen-display-id">{props.displayId}</span>
			<span class="listen-meta-sep" aria-hidden="true">·</span>
			<span class="listen-title" id="listen-title">{props.title}</span>
		</div>
		<a
			id="listen-mode-switch"
			href={`/${props.slug}`}
			class="listen-close"
			aria-label="Close listen mode"
			title="Close listen mode (Esc)"
		>
			<svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" width="14" height="14">
				<path d="M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 1 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22Z"/>
			</svg>
		</a>
	</header>

	<section class="listen-stage" aria-live="polite">
		<p class="listen-paragraph listen-paragraph--placeholder" id="listen-paragraph">
			Loading audio…
		</p>
	</section>

	<footer class="listen-transport" aria-label="Playback controls">
		<div class="listen-transport-buttons">
			<div class="listen-transport-side listen-transport-side--start">
				<button
					type="button"
					id="listen-scrubber-toggle"
					class="listen-scrubber-toggle"
					aria-label="Collapse waveform seek view"
					aria-controls="listen-scrubber-row"
					aria-expanded="true"
					title="Collapse waveform seek view"
				>
					<svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" width="14" height="14"><path d="M5.22 12.78a.75.75 0 0 0 1.06 0L10 9.06l3.72 3.72a.75.75 0 1 0 1.06-1.06l-4.25-4.25a.75.75 0 0 0-1.06 0l-4.25 4.25a.75.75 0 0 0 0 1.06Z" /></svg>
				</button>
				<button
					type="button"
					id="listen-scroll-lock-toggle"
					class="listen-scroll-lock-toggle"
					aria-label="Unlock free scroll mode"
					title="Unlock free scroll mode"
				>
					<svg id="listen-scroll-lock-icon" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke="currentColor" aria-hidden="true" width="14" height="14">
						<path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z"/>
					</svg>
				</button>
				<details class="listen-shortcuts-details">
					<summary class="listen-shortcuts-summary" title="Keyboard shortcuts">
						<span class="sr-only">Keyboard shortcuts</span>
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="listen-shortcuts-icon" aria-hidden="true">
							<path d="M4.25 4A2.25 2.25 0 0 0 2 6.25v7.5A2.25 2.25 0 0 0 4.25 16h11.5A2.25 2.25 0 0 0 18 13.75v-7.5A2.25 2.25 0 0 0 15.75 4H4.25Zm.75 2.5a.75.75 0 0 1 .75-.75h.5a.75.75 0 0 1 0 1.5h-.5A.75.75 0 0 1 5 6.5Zm2.75 0a.75.75 0 0 1 .75-.75h.5a.75.75 0 0 1 0 1.5h-.5a.75.75 0 0 1-.75-.75Zm2.75 0a.75.75 0 0 1 .75-.75h.5a.75.75 0 0 1 0 1.5h-.5a.75.75 0 0 1-.75-.75Zm2.75 0a.75.75 0 0 1 .75-.75h.5a.75.75 0 0 1 0 1.5h-.5a.75.75 0 0 1-.75-.75ZM5 10a.75.75 0 0 1 .75-.75h8.5a.75.75 0 0 1 0 1.5h-8.5A.75.75 0 0 1 5 10Zm0 3.5a.75.75 0 0 1 .75-.75h3.5a.75.75 0 0 1 0 1.5h-3.5A.75.75 0 0 1 5 13.5Z" />
						</svg>
					</summary>
					<div class="listen-shortcuts-panel">
						<ul class="listen-shortcuts-list">
							<li>
								<span class="listen-shortcuts-keys"><kbd class="listen-shortcuts-kbd">Space</kbd></span>
								<span class="listen-shortcuts-text">Play or pause</span>
							</li>
							<li>
								<span class="listen-shortcuts-keys">
									<kbd class="listen-shortcuts-kbd">←</kbd>
									<kbd class="listen-shortcuts-kbd">→</kbd>
								</span>
								<span class="listen-shortcuts-text">Previous or next paragraph</span>
							</li>
							<li>
								<span class="listen-shortcuts-keys">
									<kbd class="listen-shortcuts-kbd">[</kbd>
									<kbd class="listen-shortcuts-kbd">]</kbd>
								</span>
								<span class="listen-shortcuts-text">Previous or next discourse</span>
							</li>
							<li>
								<span class="listen-shortcuts-keys">
									<kbd class="listen-shortcuts-kbd">−</kbd>
									<kbd class="listen-shortcuts-kbd">+</kbd>
								</span>
								<span class="listen-shortcuts-text">Slower or faster</span>
							</li>
							<li>
								<span class="listen-shortcuts-keys">
									<kbd class="listen-shortcuts-kbd">Shift</kbd>
									<kbd class="listen-shortcuts-kbd">L</kbd>
								</span>
								<span class="listen-shortcuts-text">Open listen mode (from any reading page)</span>
							</li>
							<li>
								<span class="listen-shortcuts-keys">
									<kbd class="listen-shortcuts-kbd">Shift</kbd>
									<kbd class="listen-shortcuts-kbd">Q</kbd>
								</span>
								<span class="listen-shortcuts-text">Open queue; use ↑ ↓ then Space or Enter</span>
							</li>
							<li>
								<span class="listen-shortcuts-keys"><kbd class="listen-shortcuts-kbd">Esc</kbd></span>
								<span class="listen-shortcuts-text">Switch to reading mode</span>
							</li>
						</ul>
					</div>
				</details>
			</div>
			<div class="listen-transport-main">
				<button
					type="button"
					id="listen-prev"
					class="listen-btn listen-btn--ghost"
					aria-label="Previous"
					title="Previous paragraph / discourse"
				>
					<svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" width="20" height="20"><path d="M15.79 14.77a.75.75 0 0 1-1.06.02l-4.5-4.25a.75.75 0 0 1 0-1.08l4.5-4.25a.75.75 0 1 1 1.04 1.08L11.832 10l3.938 3.71a.75.75 0 0 1 .02 1.06ZM8.284 14.77a.75.75 0 0 1-1.06.02l-4.5-4.25a.75.75 0 0 1 0-1.08l4.5-4.25a.75.75 0 1 1 1.04 1.08L4.831 10l3.938 3.71a.75.75 0 0 1 .015 1.06Z" /></svg>
				</button>
				<button type="button" id="listen-play" class="listen-btn listen-btn--primary" aria-label="Play">
					<svg id="listen-play-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="28" height="28"><path d="M8 5.14v13.72c0 .8.87 1.29 1.55.87l10.79-6.86a1.03 1.03 0 0 0 0-1.74L9.55 4.27A1.03 1.03 0 0 0 8 5.14Z"/></svg>
				</button>
				<button
					type="button"
					id="listen-next"
					class="listen-btn listen-btn--ghost"
					aria-label="Next"
					title="Next paragraph / discourse"
				>
					<svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" width="20" height="20"><path d="M4.21 5.23a.75.75 0 0 1 1.06-.02l4.5 4.25a.75.75 0 0 1 0 1.08l-4.5 4.25a.75.75 0 0 1-1.04-1.08L8.168 10 4.23 6.29a.75.75 0 0 1-.02-1.06ZM11.716 5.23a.75.75 0 0 1 1.06-.02l4.5 4.25a.75.75 0 0 1 0 1.08l-4.5 4.25a.75.75 0 0 1-1.04-1.08L15.169 10l-3.94-3.71a.75.75 0 0 1-.014-1.06Z" /></svg>
				</button>
			</div>
			<div class="listen-transport-side listen-transport-side--end">
				<button
					type="button"
					id="listen-autoplay-toggle"
					class="listen-autoplay-toggle"
					aria-pressed="false"
					aria-label="Autoplay next discourse after this track ends"
					title="Autoplay next discourse after this track ends"
				>
					<span class="listen-autoplay-toggle-track" aria-hidden="true">
						<span class="listen-autoplay-toggle-thumb">
							<svg viewBox="0 0 16 16" fill="none" aria-hidden="true" width="9" height="9">
								<path d="M5.25 3.9v8.2c0 .5.54.82.97.56l6.45-4.1a.66.66 0 0 0 0-1.12L6.22 3.34a.66.66 0 0 0-.97.56Z" fill="currentColor"></path>
							</svg>
						</span>
					</span>
				</button>
				<button
					type="button"
					id="listen-speed-cycle"
					class="listen-speed-cycle"
					aria-label="Cycle playback speed"
					title="Cycle playback speed (+/−)"
				>
					<span id="listen-speed-label" aria-live="polite" aria-atomic="true">1×</span>
				</button>
				<button type="button" id="listen-queue-chip" class="listen-chip" aria-label="Queue">
					<svg
						id="listen-queue-icon"
						class="listen-queue-icon"
						viewBox="0 0 20 20"
						fill="currentColor"
						aria-hidden="true"
						width="12"
						height="12"
					>
						<path d="M3 5.5a.75.75 0 0 1 .75-.75h12.5a.75.75 0 0 1 0 1.5H3.75A.75.75 0 0 1 3 5.5Zm0 4.5a.75.75 0 0 1 .75-.75h12.5a.75.75 0 0 1 0 1.5H3.75A.75.75 0 0 1 3 10Zm0 4.5a.75.75 0 0 1 .75-.75h12.5a.75.75 0 0 1 0 1.5H3.75a.75.75 0 0 1-.75-.75Z"/>
					</svg>
					<span id="listen-queue-label">Up next</span>
				</button>
			</div>
		</div>
		<div class="listen-scrubber-row" id="listen-scrubber-row">
			<span class="listen-time" id="listen-time-current">0:00</span>
			<div class="listen-seek-wrapper">
				<canvas id="listen-waveform" class="listen-waveform" aria-hidden="true"></canvas>
				<input
					id="listen-seek"
					class="listen-seek"
					type="range"
					min="0"
					max="100"
					step="0.01"
					value="0"
					aria-label="Seek"
				/>
			</div>
			<span class="listen-time" id="listen-time-total">0:00</span>
		</div>
	</footer>

	<audio id="listen-audio" preload="auto" crossorigin="anonymous" playsinline></audio>

	<div
		id="listen-track-pulse"
		class="listen-track-pulse"
		role="status"
		aria-live="polite"
		aria-hidden="true"
	>
		<span class="listen-track-pulse-countdown" id="listen-track-pulse-countdown" aria-hidden="true"></span>
		<span class="listen-track-pulse-id" id="listen-track-pulse-id"></span>
		<span class="listen-track-pulse-title" id="listen-track-pulse-title"></span>
		<span class="listen-track-pulse-description" id="listen-track-pulse-description"></span>
		<div class="listen-track-pulse-actions" id="listen-track-pulse-actions" hidden>
			<button type="button" id="listen-track-pulse-play-now" class="listen-track-pulse-btn listen-track-pulse-btn--primary">
				Play Now&nbsp;
			</button>
			<button type="button" id="listen-track-pulse-cancel" class="listen-track-pulse-btn listen-track-pulse-btn--ghost">
				Cancel
			</button>
		</div>
	</div>

	<div
		id="listen-queue-scrim"
		class="listen-queue-scrim"
		hidden
		aria-hidden="true"
	></div>
	<aside
		id="listen-queue-drawer"
		class="listen-queue-drawer"
		role="dialog"
		aria-modal="false"
		aria-label="Queue"
		aria-hidden="true"
		hidden
	>
		<div class="listen-queue-handle" aria-hidden="true"></div>
		<header class="listen-queue-header">
			<h2 class="listen-queue-title" id="listen-queue-title">Queue</h2>
			<span
				id="listen-queue-stats"
				class="listen-queue-stats"
				aria-live="polite"
			></span>
			<button
				type="button"
				id="listen-queue-reset"
				class="listen-queue-reset"
				aria-label="Reset queue order"
				title="Reset queue order"
				hidden
			>
				Reset
			</button>
			<button
				type="button"
				id="listen-queue-close"
				class="listen-queue-close"
				aria-label="Close queue"
				title="Close queue"
			>
				<svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" width="14" height="14">
					<path d="M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 1 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22Z"/>
				</svg>
			</button>
		</header>
		<ol id="listen-queue-list" class="listen-queue-list" role="listbox" aria-label="Discourse queue"></ol>
	</aside>

	<script id="listen-initial-data" type="application/json" set:html={initialDataJson}></script>
</main>

<script>
	import { initListenMode } from "../utils/listenModeClient";
	const dataEl = document.getElementById("listen-initial-data");
	if (dataEl?.textContent) {
		try {
			const data = JSON.parse(dataEl.textContent);
			initListenMode(data);
		} catch (e) {
			console.error("listen-mode: failed to parse initial data", e);
		}
	}
</script>
