---
import { keyMap } from "../utils/transformId";
import { collectionAvailability } from "../data/collectionAvailability";

// Define status type for type safety
type StatusType = "review" | "complete";

// Define collection info from generated availability data
const collections = [
	{
		name: "dhp",
		suffix: "verses",
		title: "Dhammapada",
		total: collectionAvailability.dhp.total,
		status: "complete" as StatusType,
	},
	{
		name: "iti",
		suffix: "sayings",
		title: "Itivuttaka",
		total: collectionAvailability.iti.total,
		status: "complete" as StatusType,
	},
	{
		name: "ud",
		suffix: "utterances",
		title: "Udāna",
		total: collectionAvailability.ud.total,
		status: "complete" as StatusType,
	},
	{
		name: "mn",
		suffix: "discourses",
		title: "Majjhima Nikāya",
		total: collectionAvailability.mn.total,
	},
	{
		name: "snp",
		suffix: "teachings",
		title: "Sutta Nipāta",
		total: collectionAvailability.snp.total,
	},
	{
		name: "sn",
		suffix: "discourses",
		title: "Saṁyutta Nikāya",
		total: collectionAvailability.sn.total,
	},
	{
		name: "an",
		suffix: "discourses",
		title: "Aṅguttara Nikāya",
		total: collectionAvailability.an.total,
	},
	{
		name: "dn",
		suffix: "discourses",
		title: "Dīgha Nikāya",
		total: collectionAvailability.dn.total,
	},
	{
		name: "kp",
		suffix: "passages",
		title: "Khuddakapāṭha",
		total: collectionAvailability.kp.total,
		status: "complete" as StatusType,
	},
].map((collection) => {
	const avail = collectionAvailability[collection.name];
	return {
		...collection,
		readableCount: avail?.readableCount ?? 0,
		translatedCount: avail?.translatedCount ?? 0,
	};
});

// Status display configurations with proper typing
const statusConfig: Record<
	StatusType,
	{
		color: string;
		label: string;
		shortLabel: string;
	}
> = {
	review: {
		color: "bg-indigo-600",
		label: "Proofreading",
		shortLabel: "",
	},
	complete: {
		color: "bg-emerald-600",
		label: "Complete",
		shortLabel: "✓",
	},
};

function progressColor(percentage: number): string {
	if (percentage < 30) return "bg-amber-500";
	if (percentage < 70) return "bg-blue-500";
	return "bg-green-500";
}
---

<table
	class="min-w-full border-collapse my-4 bg-[var(--surface-elevated)] border border-[color:var(--surface-border)] rounded-xl overflow-hidden"
>
	<thead class="bg-[var(--surface-paper)]">
		<tr>
			<th
				class="py-2 px-4 text-left border-b border-[color:var(--surface-border)]"
				>Collection</th
			>
			<th
				class="py-2 px-4 text-left border-b border-[color:var(--surface-border)] hidden sm:table-cell"
				>Available</th
			>
			<th
				class="py-2 px-4 text-left border-b border-[color:var(--surface-border)]"
			></th>
		</tr>
	</thead>
	<tbody>
		{
			collections.map(
				({
					name,
					readableCount,
					translatedCount,
					suffix,
					title,
					total,
					status,
				}) => {
					const percentage = Math.min(
						100,
						Math.round((readableCount / total) * 100) || 0,
					);
					const translatedPercentage = Math.min(
						100,
						Math.round((translatedCount / total) * 100) || 0,
					);
					const isComplete = percentage >= 100;
					const useStackedBar = readableCount > translatedCount;

					let barColor: string;
					let statusText: string | null;

					if (isComplete && status) {
						const typedStatus = status as StatusType;
						barColor = statusConfig[typedStatus].color;
						statusText = statusConfig[typedStatus].label;
					} else {
						barColor = progressColor(percentage);
						statusText = null;
					}

					return (
						<tr class="hover:bg-[rgba(44,44,44,0.04)] dark:hover:bg-[rgba(231,220,196,0.06)]">
							<td class="py-2 px-4 border-b border-[color:var(--surface-border)] align-middle">
								<a href={name} class="flex items-center">
									<span class="font-medium">
										{keyMap[name] || name}
									</span>
									<span class="ml-2 text-xs text-gray-500 hidden sm:inline">
										({title.split(" - ")[0]})
									</span>
								</a>
							</td>
							<td class="py-2 px-4 border-b border-[color:var(--surface-border)] hidden sm:table-cell">
								<span class="font-medium">
									{readableCount.toLocaleString()}
								</span>{" "}
								{suffix}
							</td>
							<td class="py-2 px-4 border-b border-[color:var(--surface-border)]">
								<div class="text-xs text-gray-500 sm:hidden mt-1">
									{readableCount.toLocaleString()} {suffix}
								</div>
								<div class="flex items-center">
									<div class="w-full bg-[var(--surface-paper)] rounded-sm h-6 mr-1 sm:mr-2 relative border border-[color:var(--surface-border)] overflow-hidden">
										{useStackedBar ? (
											<>
												<div
													class={`absolute inset-y-0 left-0 rounded-sm transition-all duration-500 opacity-40 ${barColor}`}
													style={`width: ${percentage}%`}
												/>
												<div
													class={`absolute inset-y-0 left-0 rounded-sm transition-all duration-500 opacity-90 ${barColor}`}
													style={`width: ${translatedPercentage}%`}
												/>
												<div
													class={`absolute inset-0 flex items-center justify-center text-xs font-medium pointer-events-none ${percentage >= 50 ? "text-white" : "text-gray-700 dark:text-gray-300"}`}
												>
													{percentage}%
												</div>
											</>
										) : (
											<div
												class={`h-full rounded-sm transition-all duration-500 flex items-center justify-center text-white text-xs ${barColor}`}
												style={`width: ${isComplete ? "100" : percentage}%`}
											>
												{percentage >= 40 && (
													<span class="font-medium sm:hidden">
														{percentage}%
													</span>
												)}
												{percentage >= 15 && (
													<span class="font-medium hidden sm:inline">
														{percentage}%
													</span>
												)}
											</div>
										)}
										{percentage < 40 && (
											<div class="absolute inset-0 flex items-center justify-center text-gray-700 dark:text-gray-300 text-xs font-medium sm:hidden pointer-events-none">
												{percentage}%
											</div>
										)}
									</div>
									<div class="whitespace-nowrap text-xs sm:text-sm">
										{isComplete && status && (
											<>
												<span class="font-medium hidden sm:inline">
													{statusText}
												</span>
												<span class="font-medium sm:hidden">
													{
														statusConfig[
															status as StatusType
														].shortLabel
													}
												</span>
											</>
										)}
									</div>
								</div>
							</td>
						</tr>
					);
				},
			)
		}
	</tbody>
</table>

<div
	class="flex flex-wrap items-center gap-x-5 gap-y-2 text-xs text-[var(--text-muted)] mt-1 mb-4 px-1"
	aria-label="Progress bar legend"
>
	<div class="flex items-center gap-2">
		<span
			class="inline-flex w-8 h-4 shrink-0 rounded-sm bg-[var(--surface-paper)] border border-[color:var(--surface-border)] overflow-hidden relative"
			aria-hidden="true"
		>
			<span class="absolute inset-y-0 left-0 w-full rounded-sm bg-green-500 opacity-90"
			></span>
		</span>
		<span>Curated translation</span>
	</div>
	<div class="flex items-center gap-2">
		<span
			class="inline-flex w-8 h-4 shrink-0 rounded-sm bg-[var(--surface-paper)] border border-[color:var(--surface-border)] overflow-hidden relative"
			aria-hidden="true"
		>
			<span class="absolute inset-y-0 left-0 w-full rounded-sm bg-green-500 opacity-40"
			></span>
		</span>
		<span>Reference translation</span>
	</div>
</div>

<style>
	.h-6 {
		height: 1.5rem;
	}
</style>
