---
/**
 * DiscourseImage - Optional header image for discourse pages
 *
 * Features:
 * - Convention-based image discovery (src/assets/content-images/{id}.{ext})
 * - Carousel mode when multiple images are provided
 * - Hidden in offline mode (controlled by ImageToggle)
 * - Print-friendly (hidden)
 * - Optimized via Astro's Image component
 *
 * Toggle button is separate (ImageToggle.astro) and placed in icon row.
 */
import { Image } from "astro:assets";
import { getEntry } from "astro:content";
import { hasContentImage, type ContentImageData } from "../utils/contentImage";
import { routes } from "../utils/routes";
import ZoomIcon from "../assets/magnifying-glass-plus.svg?raw";
import { existsSync, readFileSync } from "node:fs";
import { resolve as resolvePath } from "node:path";
import { findSvgSafeCuts } from "../utils/svgSafeCuts";

interface Props {
	/** Single image or array of images from findContentImages() */
	imageData: ContentImageData | ContentImageData[];
	/** Previous discourse with a viz in same collection, if available */
	prevViz?: { slug: string; title: string } | null;
	/** Next discourse with a viz in same collection, if available */
	nextViz?: { slug: string; title: string } | null;
}

const { imageData: rawImageData, prevViz = null, nextViz = null } = Astro.props;

const formatVizSlug = (slug: string) =>
	slug.replace(/^([a-z]+)(.+)$/i, (_, prefix, rest) => `${prefix.toUpperCase()} ${rest}`);

const formatVizLabel = (viz: { slug: string; title: string }) =>
	`${formatVizSlug(viz.slug)} - ${viz.title}`;

const currentSlug = Astro.url.pathname
	.replace(/^\//, "")
	.replace(/\/$/, "")
	.split("/")
	.filter(Boolean)
	.at(-1) || "";

const fallbackCollectionPrefix = (currentSlug.match(/^[a-z]+/i)?.[0] || "").toLowerCase();

const computeFallbackVizNeighbor = async (direction: -1 | 1) => {
	if (!currentSlug || !fallbackCollectionPrefix) return null;
	const currentIndex = routes.findIndex((route) => route === currentSlug);
	if (currentIndex === -1) return null;

	for (
		let index = currentIndex + direction;
		direction < 0 ? index >= 0 : index < routes.length;
		index += direction
	) {
		const candidateSlug = routes[index];
		const candidatePrefix = (candidateSlug.match(/^[a-z]+/i)?.[0] || "").toLowerCase();
		if (candidatePrefix !== fallbackCollectionPrefix) continue;
		if (!hasContentImage(candidateSlug)) continue;
		const candidateEntry = await getEntry("all", candidateSlug);

		return {
			slug: candidateSlug,
			title: candidateEntry?.data.title || formatVizSlug(candidateSlug),
		};
	}

	return null;
};

const resolvedPrevViz = prevViz ?? (await computeFallbackVizNeighbor(-1));
const resolvedNextViz = nextViz ?? (await computeFallbackVizNeighbor(1));

const buildVizHref = (slug: string) => {
	const params = new URLSearchParams(Astro.url.search);
	params.delete("image");
	params.set("viz", "1");
	return `/${slug}?${params.toString()}`;
};

const prevVizHref = resolvedPrevViz ? buildVizHref(resolvedPrevViz.slug) : null;
const nextVizHref = resolvedNextViz ? buildVizHref(resolvedNextViz.slug) : null;

// Normalize to array
const allImages = Array.isArray(rawImageData) ? rawImageData : [rawImageData];
const isCarousel = allImages.length > 1;

// Standard width for content area - Astro will maintain aspect ratio
const IMAGE_WIDTH = 800;

// Process each image for rendering
const processedImages = allImages.map((img) => {
	const modulePath = img.modulePath;
	const isSvg = modulePath.toLowerCase().endsWith(".svg");

	// In dev, ensure the source file exists to avoid broken images
	const devFileExists = (() => {
		if (!import.meta.env.DEV) return true;
		try {
			const abs = resolvePath(process.cwd(), modulePath.replace(/^\//, ""));
			return existsSync(abs);
		} catch {
			return true;
		}
	})();

	// Derive a stable public permalink in /content-images/ based on the module path
	// Example: /src/assets/content-images/an3.65.webp -> /content-images/an3.65.webp
	// In dev, only use the public URL if the file actually exists; otherwise
	// fall back to the bundled asset URL to avoid broken images.
	let publicUrl: string | undefined;
	const marker = "/content-images/";
	const idx = modulePath.lastIndexOf(marker);
	if (idx !== -1) {
		const filename = modulePath.slice(idx + marker.length);
		if (filename) {
			if (!import.meta.env.DEV) {
				publicUrl = `/content-images/${filename}`;
			} else {
				try {
					const absPublic = resolvePath(
						process.cwd(),
						"public",
						"content-images",
						filename,
					);
					if (existsSync(absPublic)) {
						publicUrl = `/content-images/${filename}`;
					}
				} catch {
					// If checking public fails, just skip the permalink in dev.
					publicUrl = undefined;
				}
			}
		}
	}

	const width = (img.image as any)?.width;
	const height = (img.image as any)?.height;
	const aspectRatio =
		typeof width === "number" && typeof height === "number" && height > 0
			? width / height
			: null;
	const isWithinFitBand =
		aspectRatio != null && aspectRatio >= 1.2 && aspectRatio <= 1.69;
	const isPortrait =
		aspectRatio != null && aspectRatio < 0.9;
	const svgMarkup = (() => {
		if (!isSvg) return undefined;
		try {
			const abs = resolvePath(process.cwd(), modulePath.replace(/^\//, ""));
			if (!existsSync(abs)) return undefined;
			let raw = readFileSync(abs, "utf-8")
				.replace(/(<svg[^>]*?)\s+width="[^"]*"/i, "$1")
				.replace(/(<svg[^>]*?)\s+height="[^"]*"/i, "$1");
			// Set width:100% so the SVG fills the content column and is readable.
			// No max-height — tall images flow across page breaks in print.
			raw = raw.replace(
				/(<svg\b[^>]*?)(\s*>)/i,
				`$1 style="width:100%;height:auto"$2`
			);
			return raw;
		} catch {
			return undefined;
		}
	})();

	// Compute safe Y-cut positions for print slicing (avoids cutting through text/shapes)
	const safeCuts = svgMarkup ? findSvgSafeCuts(svgMarkup) : null;

	return {
		...img,
		isSvg,
		devFileExists,
		isWithinFitBand,
		isPortrait,
		publicUrl,
		svgMarkup,
		safeCuts,
	};
});

// Filter to only existing images
const images = processedImages.filter((img) => img.devFileExists);

const parseInitialVizIndex = () => {
	const vizParam =
		Astro.url.searchParams.get("viz") ??
		Astro.url.searchParams.get("image");
	if (vizParam == null) return null;
	if (vizParam === "" || vizParam === "true") return 0;
	const parsed = parseInt(vizParam, 10);
	if (!Number.isNaN(parsed) && parsed >= 1) return parsed - 1;
	return 0;
};

const initialVizIndexRaw = parseInitialVizIndex();
const initialVizIndex =
	initialVizIndexRaw == null
		? 0
		: Math.max(0, Math.min(images.length - 1, initialVizIndexRaw));
const initialVizOpen = initialVizIndexRaw != null;
const initialImage = images[initialVizIndex];
if (!initialImage) return;
---

{images.length > 0 && (
	<figure
		id="discourseImageFigure"
		class="discourse-image not-prose group relative m-0 mb-3 hidden w-full md:max-w-3xl"
		data-carousel={isCarousel ? "true" : undefined}
	>
	<script is:inline>
		try {
			const stored = localStorage.getItem("showDiscourseImages");
			const show = stored === null ? true : stored === "true";
			const hasViz = /[?&](viz|image)=/.test(window.location.search);
			const canShowImages = show && navigator.onLine;
			const fig = document.getElementById("discourseImageFigure");
			if (hasViz && !canShowImages) {
				const url = new URL(window.location.href);
				url.searchParams.delete("viz");
				url.searchParams.delete("image");
				history.replaceState(history.state, "", `${url.pathname}${url.search}${url.hash}`);
				document.documentElement.style.removeProperty("--viz-preload");
				fig.classList.add("hidden");
			} else if (hasViz) {
				fig.classList.remove("hidden");
			} else if (canShowImages) {
				fig.classList.remove("hidden");
			}
		} catch (e) {}
	</script>

	<div class="image-frame relative rounded-lg overflow-hidden">
		<button
			id="openImageOverlay"
			type="button"
			class="absolute inset-0 z-[5] w-full h-full cursor-zoom-in focus:outline-none focus-visible:ring-2 focus-visible:ring-amber-500/90 focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:focus-visible:ring-offset-gray-900"
			aria-label="View full image"
		/>
		{/* Carousel wrapper */}
		<div id="carouselTrack" class="relative w-full z-0">
			{images.map((img, idx) => (
				<div
					class:list={[
						"carousel-slide w-full",
						idx === initialVizIndex ? "" : "hidden",
					]}
					data-slide-index={idx}
					data-permalink={img.publicUrl}
				>
					{img.isSvg ? (
						img.svgMarkup ? (
							<>
								<img
									src={img.publicUrl ?? img.image.src}
									alt={img.alt}
									class:list={[
										"svg-image svg-screen w-full h-auto rounded-lg object-contain",
										img.isPortrait && "svg-portrait",
										img.isWithinFitBand ? "max-h-[440px]" : "max-h-[320px]",
									]}
									loading={idx === 0 ? "eager" : "lazy"}
									decoding="async"
								/>
								<div
									class:list={["svg-print", img.isPortrait && "svg-portrait"]}
									data-safe-cuts={img.safeCuts ? img.safeCuts.join(",") : undefined}
									set:html={img.svgMarkup}
								/>
							</>
						) : (
							<img
								src={img.publicUrl ?? img.image.src}
								alt={img.alt}
								class:list={[
									"svg-image w-full h-auto rounded-lg object-contain",
									img.isPortrait && "svg-portrait",
									img.isWithinFitBand ? "max-h-[440px]" : "max-h-[320px]",
								]}
								loading={idx === 0 ? "eager" : "lazy"}
								decoding="async"
							/>
						)
					) : (
						<Image
							src={img.image}
							alt={img.alt}
							width={IMAGE_WIDTH}
							class:list={[
								"w-full h-auto rounded-lg",
								img.isWithinFitBand
									? "object-cover max-h-[440px]"
									: "object-cover max-h-[320px]",
							]}
							loading={idx === 0 ? "eager" : "lazy"}
							decoding="async"
						/>
					)}
				</div>
			))}
		</div>

		{/* Carousel navigation arrows */}
		{isCarousel && (
			<>
				<button
					id="carouselPrev"
					class="absolute left-2 top-1/2 -translate-y-1/2 w-9 h-9 bg-black/50 hover:bg-black/70 text-white rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-200 flex items-center justify-center p-0 z-10"
					title="Previous image"
					aria-label="Previous image"
				>
					<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
					</svg>
				</button>
				<button
					id="carouselNext"
					class="absolute right-12 top-1/2 -translate-y-1/2 w-9 h-9 bg-black/50 hover:bg-black/70 text-white rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-200 flex items-center justify-center p-0 z-10"
					title="Next image"
					aria-label="Next image"
				>
					<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
					</svg>
				</button>
			</>
		)}

		{/* Zoom button */}
		<button
			id="expandImageBtn"
			class="absolute top-2 right-2 w-8 h-8 bg-black/50 hover:bg-black/70 text-white rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-200 flex items-center justify-center p-0 z-10 focus:outline-none select-none"
			title="View full image"
			aria-label="View full image"
		>
			<span
				class="w-5 h-5 flex items-center justify-center pointer-events-none select-none"
				set:html={ZoomIcon}
			/>
		</button>
	</div>

	{/* Carousel dots */}
	{isCarousel && (
		<div id="carouselDots" class="flex justify-center gap-2 mt-2">
			{images.map((_, idx) => (
				<button
					class:list={[
						"carousel-dot w-2 h-2 rounded-full transition-all duration-200",
						idx === initialVizIndex
							? "bg-amber-500 dark:bg-amber-400 w-4"
							: "bg-gray-400 dark:bg-gray-600 hover:bg-gray-500",
					]}
					data-dot-index={idx}
					aria-label={`Go to image ${idx + 1}`}
				/>
			))}
		</div>
	)}

	{
		initialImage.caption && (
			<figcaption class="mt-0.5 text-sm text-gray-600 dark:text-gray-400 text-center">
				{initialImage.caption}
			</figcaption>
		)
	}

	{/* Zoom modal — shows current slide's image with carousel nav */}
	<dialog
		id="imageModal"
		open={initialVizOpen ? true : undefined}
		class:list={[
			"p-0 bg-transparent backdrop:bg-black/80 max-w-none max-h-none w-full h-full m-0 open:flex items-center justify-center pointer-events-none open:pointer-events-auto",
			initialVizOpen && "viz-initial-open fixed inset-0 bg-black/80 flex items-center justify-center pointer-events-auto",
		]}
	>
		<form
			method="dialog"
			class="fixed z-10 top-[max(1rem,env(safe-area-inset-top))] right-[max(1rem,env(safe-area-inset-right))]"
		>
			<button
				class="w-12 h-12 inline-flex items-center justify-center text-white hover:text-gray-300 focus:outline-none"
				aria-label="Close"
			>
				<svg
					xmlns="http://www.w3.org/2000/svg"
					class="h-8 w-8"
					fill="none"
					viewBox="0 0 24 24"
					stroke="currentColor"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M6 18L18 6M6 6l12 12"
					/>
				</svg>
			</button>
		</form>

		{/* Modal carousel arrows (retained only when no discourse viz nav exists) */}
		{isCarousel && !resolvedPrevViz && !resolvedNextViz && (
			<>
				<button
					id="modalPrev"
					class="fixed top-1/2 z-10 flex h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full bg-white/15 p-0 text-white transition-colors duration-200 hover:bg-white/30 left-[max(1rem,env(safe-area-inset-left))]"
					title="Previous image"
					aria-label="Previous image"
				>
					<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
					</svg>
				</button>
				<button
					id="modalNext"
					class="fixed top-1/2 z-10 flex h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full bg-white/15 p-0 text-white transition-colors duration-200 hover:bg-white/30 right-[max(1rem,env(safe-area-inset-right))]"
					title="Next image"
					aria-label="Next image"
				>
					<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
					</svg>
				</button>
			</>
		)}

		<div
			id="modalViewport"
			class="fixed inset-0 z-0 h-dvh w-full overflow-auto overscroll-contain rounded-none pl-[env(safe-area-inset-left,0px)] pr-[env(safe-area-inset-right,0px)]"
		>
			<div
				id="modalZoomContent"
				class="box-border flex min-h-full min-w-full w-full flex-col px-0 pt-0 pb-[calc(5.25rem+env(safe-area-inset-bottom,0px))]"
			>
				<div class="flex w-full flex-1 items-center justify-center">
					<img
						id="fullImage"
						src={initialImage.publicUrl ?? initialImage.image.src}
						alt={initialImage.alt}
						width={initialImage.isSvg ? undefined : IMAGE_WIDTH}
						class:list={[
							"w-full h-auto object-contain rounded-lg",
							initialImage.isSvg ? "hidden" : "shadow-2xl",
						]}
					/>
					<object
						id="fullSvgObject"
						data={initialImage.publicUrl ?? initialImage.image.src}
						type="image/svg+xml"
						role="img"
						aria-label={initialImage.alt}
						class:list={[
							"w-full h-auto rounded-lg",
							initialImage.isSvg ? "svg-image" : "hidden",
						]}
					/>
				</div>
				{initialImage.caption && (
					<p
						class="viz-modal-caption mx-auto mt-2 max-w-[min(42rem,calc(100%-2rem))] shrink-0 rounded-lg bg-black/55 px-3 py-1.5 text-center text-[13px] leading-snug text-white/95 ring-1 ring-white/15 backdrop-blur-md"
					>
						{initialImage.caption}
					</p>
				)}
			</div>

			{resolvedPrevViz && prevVizHref && (
					<a
						href={prevVizHref}
						class="viz-nav-link fixed bottom-[max(1.25rem,env(safe-area-inset-bottom))] left-[max(1.25rem,env(safe-area-inset-left))] z-20 rounded-md bg-black/70 px-2.5 py-1 text-[11px] font-medium text-white/95 shadow-lg ring-1 ring-white/20 backdrop-blur-md transition-colors duration-200 hover:bg-black/85 hover:text-white"
						title={formatVizLabel(resolvedPrevViz)}
						aria-label={`Previous Viz: ${formatVizLabel(resolvedPrevViz)}`}
					>
						← {formatVizSlug(resolvedPrevViz.slug)}
					</a>
				)}
				{resolvedNextViz && nextVizHref && (
					<a
						href={nextVizHref}
						class="viz-nav-link fixed bottom-[max(1.25rem,env(safe-area-inset-bottom))] right-[max(1.25rem,env(safe-area-inset-right))] z-20 rounded-md bg-black/70 px-2.5 py-1 text-[11px] font-medium text-white/95 shadow-lg ring-1 ring-white/20 backdrop-blur-md transition-colors duration-200 hover:bg-black/85 hover:text-white"
						title={formatVizLabel(resolvedNextViz)}
						aria-label={`Next Viz: ${formatVizLabel(resolvedNextViz)}`}
					>
						{formatVizSlug(resolvedNextViz.slug)} →
					</a>
				)}

			<div class="fixed left-1/2 z-20 flex -translate-x-1/2 items-center gap-2 rounded-full bg-black/50 px-3 py-2 backdrop-blur-sm bottom-[max(1rem,env(safe-area-inset-bottom))]">
				<button
					id="zoomOutBtn"
					type="button"
					class="h-9 w-9 rounded-full bg-white/15 hover:bg-white/30 text-white text-xl leading-none disabled:opacity-40 disabled:cursor-not-allowed disabled:hover:bg-white/15"
					aria-label="Zoom out"
					title="Zoom out"
				>
					-
				</button>
				<button
					id="zoomResetBtn"
					type="button"
					class="h-9 rounded-full bg-white/15 hover:bg-white/30 text-white text-xs px-3 disabled:opacity-40 disabled:cursor-not-allowed disabled:hover:bg-white/15"
					aria-label="Reset zoom"
					title="Reset zoom"
				>
					Reset
				</button>
				<button
					id="zoomInBtn"
					type="button"
					class="h-9 w-9 rounded-full bg-white/15 hover:bg-white/30 text-white text-xl leading-none disabled:opacity-40 disabled:cursor-not-allowed disabled:hover:bg-white/15"
					aria-label="Zoom in"
					title="Zoom in"
				>
					+
				</button>
			</div>
			{/* Modal dots */}
			{isCarousel && (
				<div
					id="modalDots"
					class="fixed bottom-[4.75rem] left-1/2 -translate-x-1/2 z-20 flex justify-center gap-2.5"
				>
					{images.map((_, idx) => (
						<button
							class:list={[
								"modal-dot w-2.5 h-2.5 rounded-full transition-all duration-200",
								idx === 0
									? "bg-amber-400 w-5"
									: "bg-white/40 hover:bg-white/60",
							]}
							data-modal-dot-index={idx}
							aria-label={`Go to image ${idx + 1}`}
						/>
					))}
				</div>
			)}
		</div>
	</dialog>
	</figure>
)}

<script>
	function initDiscourseImage() {
		const figure = document.getElementById("discourseImageFigure");
		const expandBtn = document.getElementById("expandImageBtn");
		const overlayBtn = document.getElementById("openImageOverlay");
		const dialog = document.getElementById("imageModal") as HTMLDialogElement;
		const fullImage = document.getElementById("fullImage") as HTMLImageElement;
		const fullSvgObject = document.getElementById("fullSvgObject") as HTMLObjectElement;
		const modalViewport = document.getElementById("modalViewport") as HTMLElement;
		const modalZoomContent = document.getElementById("modalZoomContent") as HTMLElement;
		const zoomInBtn = document.getElementById("zoomInBtn") as HTMLButtonElement;
		const zoomOutBtn = document.getElementById("zoomOutBtn") as HTMLButtonElement;
		const zoomResetBtn = document.getElementById("zoomResetBtn") as HTMLButtonElement;
		let lockedScrollY = 0;
		/** Saved viewport meta while viz modal is open — restored on unlock (see lockPageScroll). */
		let savedViewportContent: string | null = null;

		if (!figure) return;

		// --- Carousel logic ---
		const isCarousel = figure.dataset.carousel === "true";
		let currentSlide = 0;
		const slides = figure.querySelectorAll<HTMLElement>(".carousel-slide");
		const dots = figure.querySelectorAll<HTMLElement>(".carousel-dot");
		const totalSlides = slides.length;

		// Collect all image sources for modal navigation, preferring stable public permalinks
		const imageSources: { src: string; alt: string; isSvg: boolean }[] = [];
		slides.forEach((slide) => {
			const slideEl = slide as HTMLElement;
			const img = slide.querySelector("img") as HTMLImageElement | null;
			const permalink = slideEl.dataset.permalink;
			const src = permalink || img?.src;
			const alt = img?.alt || "Discourse image";
			if (!src) return;
			imageSources.push({
				src,
				alt,
				isSvg: src.toLowerCase().endsWith(".svg"),
			});
		});

		const modalDots = figure.querySelectorAll<HTMLElement>(".modal-dot");
		const MIN_ZOOM_PERCENT = 100;
		const MAX_ZOOM_PERCENT = 300;
		const ZOOM_STEP_PERCENT = 25;
		const IMAGE_QUERY_PARAM = "viz";
		const IMAGE_QUERY_PARAM_FALLBACK = "image";
		let zoomPercent = 100;

		const updateZoomButtons = () => {
			if (zoomOutBtn) {
				zoomOutBtn.disabled = zoomPercent <= MIN_ZOOM_PERCENT;
			}
			if (zoomInBtn) {
				zoomInBtn.disabled = zoomPercent >= MAX_ZOOM_PERCENT;
			}
			if (zoomResetBtn) {
				zoomResetBtn.disabled = zoomPercent <= MIN_ZOOM_PERCENT;
			}
		};

		const centerViewport = () => {
			if (!modalViewport) return;
			const maxLeft = Math.max(0, modalViewport.scrollWidth - modalViewport.clientWidth);
			const maxTop = Math.max(0, modalViewport.scrollHeight - modalViewport.clientHeight);
			modalViewport.scrollLeft = maxLeft / 2;
			modalViewport.scrollTop = maxTop / 2;
		};

		/** Keeps scroll offset valid after zoom / browser visual-viewport changes (mobile pinch vs in-modal zoom). */
		const clampModalScroll = () => {
			if (!modalViewport) return;
			const maxL = Math.max(0, modalViewport.scrollWidth - modalViewport.clientWidth);
			const maxT = Math.max(0, modalViewport.scrollHeight - modalViewport.clientHeight);
			modalViewport.scrollLeft = Math.min(Math.max(0, modalViewport.scrollLeft), maxL);
			modalViewport.scrollTop = Math.min(Math.max(0, modalViewport.scrollTop), maxT);
		};

		const scheduleClampModalScroll = () => {
			requestAnimationFrame(() => {
				requestAnimationFrame(() => {
					clampModalScroll();
				});
			});
		};

		const applyZoom = () => {
			if (modalZoomContent) {
				if (zoomPercent === 100) {
					modalZoomContent.style.removeProperty("width");
				} else {
					modalZoomContent.style.width = `${zoomPercent}%`;
				}
			}
			updateZoomButtons();
		};

		const setZoom = (nextZoomPercent: number) => {
			if (!modalViewport) {
				zoomPercent = Math.max(
					MIN_ZOOM_PERCENT,
					Math.min(MAX_ZOOM_PERCENT, nextZoomPercent),
				);
				applyZoom();
				return;
			}

			const prevZoomPercent = zoomPercent;
			const prevScrollLeft = modalViewport.scrollLeft;
			const prevScrollTop = modalViewport.scrollTop;
			const viewportWidth = modalViewport.clientWidth;
			const viewportHeight = modalViewport.clientHeight;

			zoomPercent = Math.max(
				MIN_ZOOM_PERCENT,
				Math.min(MAX_ZOOM_PERCENT, nextZoomPercent),
			);

			if (zoomPercent === prevZoomPercent) {
				applyZoom();
				return;
			}

			applyZoom();

			requestAnimationFrame(() => {
				const scale = zoomPercent / prevZoomPercent;
				const focusX = prevScrollLeft + viewportWidth / 2;
				const focusY = prevScrollTop + viewportHeight / 2;
				modalViewport.scrollLeft = Math.max(0, focusX * scale - viewportWidth / 2);
				modalViewport.scrollTop = Math.max(0, focusY * scale - viewportHeight / 2);
				requestAnimationFrame(() => {
					clampModalScroll();
				});
			});
		};

		const resetZoom = () => {
			zoomPercent = 100;
			applyZoom();
			scheduleClampModalScroll();
		};

		const parseImageRouteIndex = (): number | null => {
			const url = new URL(window.location.href);
			const imageParam =
				url.searchParams.get(IMAGE_QUERY_PARAM) ??
				url.searchParams.get(IMAGE_QUERY_PARAM_FALLBACK);

			if (imageParam != null) {
				if (imageParam === "" || imageParam === "true") return 0;
				const parsed = parseInt(imageParam, 10);
				if (!Number.isNaN(parsed) && parsed >= 1) return parsed - 1;
				return 0;
			}

			return null;
		};

		const setImageRoute = (index: number) => {
			const url = new URL(window.location.href);
			url.searchParams.set(IMAGE_QUERY_PARAM, `${index + 1}`);
			history.replaceState(history.state, "", `${url.pathname}${url.search}${url.hash}`);
		};

		const clearImageRoute = () => {
			const url = new URL(window.location.href);
			if (
				!url.searchParams.has(IMAGE_QUERY_PARAM) &&
				!url.searchParams.has(IMAGE_QUERY_PARAM_FALLBACK)
			) {
				return;
			}

			url.searchParams.delete(IMAGE_QUERY_PARAM);
			url.searchParams.delete(IMAGE_QUERY_PARAM_FALLBACK);
			history.replaceState(history.state, "", `${url.pathname}${url.search}${url.hash}`);
		};

		const lockPageScroll = () => {
			if (document.body.dataset.discourseImageScrollLock === "true") return;
			lockedScrollY = window.scrollY;
			document.body.dataset.discourseImageScrollLock = "true";
			document.body.style.overflow = "hidden";
			document.body.style.position = "fixed";
			document.body.style.top = `-${lockedScrollY}px`;
			document.body.style.left = "0";
			document.body.style.right = "0";
			document.body.style.width = "100%";

			// Prevent browser pinch-zoom from stacking with in-modal zoom (Safari / Chrome).
			// Restored in unlockPageScroll. Pinch is handled via two-finger touch → setZoom below.
			const meta = document.querySelector('meta[name="viewport"]');
			if (meta && savedViewportContent === null) {
				savedViewportContent = meta.getAttribute("content");
				meta.setAttribute(
					"content",
					"width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover",
				);
			}
		};

		const unlockPageScroll = () => {
			if (document.body.dataset.discourseImageScrollLock !== "true") return;
			document.body.dataset.discourseImageScrollLock = "false";
			document.body.style.overflow = "";
			document.body.style.position = "";
			document.body.style.top = "";
			document.body.style.left = "";
			document.body.style.right = "";
			document.body.style.width = "";
			// Also clear any <html>-level overflow set by early viz-preload script
			document.documentElement.style.overflow = "";
			document.documentElement.style.removeProperty('--viz-preload');
			window.scrollTo(0, lockedScrollY);

			const meta = document.querySelector('meta[name="viewport"]');
			if (meta && savedViewportContent !== null) {
				meta.setAttribute("content", savedViewportContent);
				savedViewportContent = null;
			}
		};

		function updateModalSlide(index: number) {
			if (!fullImage || !fullSvgObject) return;
			const source = imageSources[index];
			if (source) {
				if (source.isSvg) {
					fullSvgObject.data = source.src;
					fullSvgObject.setAttribute("aria-label", source.alt);
					fullSvgObject.classList.remove("hidden");
					fullImage.classList.add("hidden");
				} else {
					fullImage.src = source.src;
					fullImage.alt = source.alt;
					fullImage.classList.remove("hidden");
					fullImage.classList.add("shadow-2xl");
					fullSvgObject.classList.add("hidden");
				}
			}
			// Update modal dots
			modalDots.forEach((dot, i) => {
				dot.classList.toggle("bg-amber-400", i === index);
				dot.classList.toggle("w-5", i === index);
				dot.classList.toggle("bg-white/40", i !== index);
				dot.classList.toggle("hover:bg-white/60", i !== index);
				dot.classList.toggle("w-2.5", i !== index);
			});
			resetZoom();
		}

		const openModalAt = (index: number, updateRoute: boolean) => {
			const clampedIndex = Math.max(0, Math.min(totalSlides - 1, index));
			goToSlide(clampedIndex);

			if (dialog && !dialog.open) {
				dialog.showModal();
				lockPageScroll();
				scheduleClampModalScroll();
			}

			if (updateRoute) {
				setImageRoute(clampedIndex);
			}
		};

		const shouldIgnoreOpenClick = (evtTarget: EventTarget | null) => {
			const el = evtTarget as Element | null;
			if (!el) return false;
			// Don't hijack clicks meant for controls/links inside the frame.
			return Boolean(el.closest("button, a, input, textarea, select, summary, details"));
		};

		function goToSlide(index: number) {
			if (index < 0) index = totalSlides - 1;
			if (index >= totalSlides) index = 0;

			slides.forEach((slide, i) => {
				slide.classList.toggle("hidden", i !== index);
			});
			dots.forEach((dot, i) => {
				dot.classList.toggle("bg-amber-500", i === index);
				dot.classList.toggle("dark:bg-amber-400", i === index);
				dot.classList.toggle("w-4", i === index);
				dot.classList.toggle("bg-gray-400", i !== index);
				dot.classList.toggle("dark:bg-gray-600", i !== index);
				dot.classList.toggle("hover:bg-gray-500", i !== index);
				dot.classList.toggle("w-2", i !== index);
			});

			currentSlide = index;
			updateModalSlide(index);
		}

		if (isCarousel) {
			const prevBtn = document.getElementById("carouselPrev");
			const nextBtn = document.getElementById("carouselNext");

			prevBtn?.addEventListener("click", (e) => {
				e.stopPropagation();
				goToSlide(currentSlide - 1);
			});
			nextBtn?.addEventListener("click", (e) => {
				e.stopPropagation();
				goToSlide(currentSlide + 1);
			});

			dots.forEach((dot) => {
				dot.addEventListener("click", () => {
					const idx = parseInt(dot.dataset.dotIndex || "0", 10);
					goToSlide(idx);
				});
			});

			const modalPrev = document.getElementById("modalPrev");
			const modalNext = document.getElementById("modalNext");

			modalPrev?.addEventListener("click", (e) => {
				e.stopPropagation();
				goToSlide(currentSlide - 1);
			});
			modalNext?.addEventListener("click", (e) => {
				e.stopPropagation();
				goToSlide(currentSlide + 1);
			});

			modalDots.forEach((dot) => {
				dot.addEventListener("click", (e) => {
					e.stopPropagation();
					const idx = parseInt(dot.dataset.modalDotIndex || "0", 10);
					goToSlide(idx);
				});
			});

			// Keyboard navigation — works on both figure and modal
			const handleKeyNav = (e: KeyboardEvent) => {
				if (e.key === "ArrowLeft") { e.preventDefault(); goToSlide(currentSlide - 1); }
				if (e.key === "ArrowRight") { e.preventDefault(); goToSlide(currentSlide + 1); }
			};
			figure.addEventListener("keydown", handleKeyNav);
			dialog?.addEventListener("keydown", handleKeyNav);
			figure.setAttribute("tabindex", "0");
		}

		// --- Zoom logic ---
		if (expandBtn && dialog) {
			expandBtn.addEventListener("click", (e) => {
				e.stopPropagation();
				openModalAt(currentSlide, true);
			});

			dialog.addEventListener("click", (e) => {
				if (e.target === dialog) {
					dialog.close();
				}
			});

			dialog.addEventListener("close", () => {
				resetZoom();
				unlockPageScroll();
				clearImageRoute();
				// Re-trigger paragraph alignment for split Pali layout —
				// it skips alignment at load when viz-preload hides the body.
				window.dispatchEvent(new Event('resize'));
			});

			dialog.addEventListener(
				"touchmove",
				(e) => {
					if (!modalViewport) return;
					if (!modalViewport.contains(e.target as Node)) {
						e.preventDefault();
					}
				},
				{ passive: false },
			);
		}

		// Click anywhere on the image frame to open the modal.
		// The overlay is an empty <button> — e.target is always the overlay itself, no guard needed.
		overlayBtn?.addEventListener("click", () => {
			openModalAt(currentSlide, true);
		});

		if (zoomInBtn) {
			zoomInBtn.addEventListener("click", (e) => {
				e.stopPropagation();
				setZoom(zoomPercent + ZOOM_STEP_PERCENT);
			});
		}

		if (zoomOutBtn) {
			zoomOutBtn.addEventListener("click", (e) => {
				e.stopPropagation();
				setZoom(zoomPercent - ZOOM_STEP_PERCENT);
			});
		}

		if (zoomResetBtn) {
			zoomResetBtn.addEventListener("click", (e) => {
				e.stopPropagation();
				resetZoom();
			});
		}

		if (modalViewport) {
			modalViewport.addEventListener(
				"wheel",
				(e) => {
					if (!e.ctrlKey && !e.metaKey) return;
					e.preventDefault();
					const direction = e.deltaY < 0 ? 1 : -1;
					setZoom(zoomPercent + direction * ZOOM_STEP_PERCENT);
				},
				{ passive: false },
			);
		}

		// Mobile: browser pinch-zoom stacks badly with in-modal width zoom; viewport is locked in lockPageScroll.
		// Two-finger pinch on the image area drives the same setZoom as the +/- buttons.
		let pinchStartDist = 0;
		let pinchStartZoom = 100;
		const touchDistance = (touches: TouchList) =>
			Math.hypot(
				touches[0].clientX - touches[1].clientX,
				touches[0].clientY - touches[1].clientY,
			);

		if (!(figure as HTMLElement).dataset.vizModalGesturesAttached) {
			(figure as HTMLElement).dataset.vizModalGesturesAttached = "true";

			const vv = window.visualViewport;
			if (vv) {
				const onViewportChange = () => {
					const d = document.getElementById("imageModal") as HTMLDialogElement | null;
					if (!d?.open) return;
					clampModalScroll();
				};
				vv.addEventListener("resize", onViewportChange);
				vv.addEventListener("scroll", onViewportChange);
			}

			if (modalViewport) {
				modalViewport.addEventListener(
					"touchstart",
					(e) => {
						if (e.touches.length === 2) {
							pinchStartDist = touchDistance(e.touches);
							pinchStartZoom = zoomPercent;
						}
					},
					{ passive: true },
				);

				const endPinch = () => {
					pinchStartDist = 0;
				};
				modalViewport.addEventListener("touchend", endPinch, { passive: true });
				modalViewport.addEventListener("touchcancel", endPinch, { passive: true });

				modalViewport.addEventListener(
					"touchmove",
					(e) => {
						if (e.touches.length !== 2 || pinchStartDist < 8) return;
						e.preventDefault();
						const dist = touchDistance(e.touches);
						const ratio = dist / pinchStartDist;
						const next = Math.round(pinchStartZoom * ratio);
						setZoom(Math.max(MIN_ZOOM_PERCENT, Math.min(MAX_ZOOM_PERCENT, next)));
					},
					{ passive: false },
				);
			}
		}

		dialog?.addEventListener("keydown", (e) => {
			if (e.key === "+" || e.key === "=") {
				e.preventDefault();
				setZoom(zoomPercent + ZOOM_STEP_PERCENT);
			}
			if (e.key === "-") {
				e.preventDefault();
				setZoom(zoomPercent - ZOOM_STEP_PERCENT);
			}
			if (e.key === "0") {
				e.preventDefault();
				resetZoom();
			}
		});

		// Viz mode requires images to be enabled and online; otherwise fallback to normal page view.
		const closeVizAndFallback = () => {
			if (dialog?.open) {
				dialog.close();
				unlockPageScroll();
			}
			clearImageRoute();
			document.documentElement.style.removeProperty("--viz-preload");
		};

		const syncModalWithRoute = () => {
			if (!canShowImages()) {
				closeVizAndFallback();
				return;
			}

			const requestedIndex = parseImageRouteIndex();
			if (requestedIndex == null) {
				if (dialog?.open) {
					dialog.close();
					unlockPageScroll();
				}
				return;
			}

			openModalAt(requestedIndex, false);
		};

		// --- Visibility logic ---
		const STORAGE_KEY = "showDiscourseImages";

		const getPreference = (): boolean => {
			const stored = localStorage.getItem(STORAGE_KEY);
			return stored === null ? true : stored === "true";
		};

		const isOffline = (): boolean => !navigator.onLine;
		const canShowImages = (): boolean => !isOffline() && getPreference();

		const updateVisibility = () => {
			const show = canShowImages();
			figure.classList.toggle("hidden", !show);

			if (!show) {
				closeVizAndFallback();
			}
		};

		updateVisibility();

		window.addEventListener("online", updateVisibility);
		window.addEventListener("offline", updateVisibility);
		window.addEventListener("storage", (e) => {
			if (e.key === STORAGE_KEY) updateVisibility();
		});
		window.addEventListener("popstate", syncModalWithRoute);

		document.addEventListener("discourseImageToggled", updateVisibility);
		resetZoom();

		// Transition from server-side <dialog open> to a proper showModal().
		// The server renders with `open` + `viz-initial-open` so the dialog
		// is visible before JS loads, but we need showModal() for proper
		// backdrop, focus-trap, and top-layer stacking.
		if (dialog && dialog.classList.contains('viz-initial-open')) {
			dialog.close();
			dialog.classList.remove('viz-initial-open');
			dialog.showModal();
			lockPageScroll();
			scheduleClampModalScroll();
		} else {
			syncModalWithRoute();
		}
	}

	initDiscourseImage();
	document.addEventListener("astro:page-load", initDiscourseImage);
</script>

<style>
	.discourse-image {
		transition: opacity 0.2s ease-in-out;
	}

	.discourse-image.hidden {
		display: none;
	}

	.svg-print {
		display: none;
	}

	.discourse-image img:not(.svg-image) {
		filter: brightness(0.98);
	}

	:global(.dark) .discourse-image img:not(.svg-image) {
		filter: brightness(0.92);
	}

	.image-frame,
	.image-frame img,
	.image-frame object {
		cursor: zoom-in;
	}

	/* Keep normal cursors for controls */
	#expandImageBtn,
	#carouselPrev,
	#carouselNext,
	.carousel-dot {
		cursor: pointer;
	}

	.carousel-slide {
		transition: opacity 0.3s ease-in-out;
	}

	.viz-nav-link,
	.viz-nav-link:visited,
	.viz-nav-link:hover,
	.viz-nav-link:active {
		text-decoration: none !important;
	}

	/* Readable on any image (overrides prose / theme link colors) */
	.viz-nav-link {
		color: rgba(255, 255, 255, 0.95) !important;
	}

	.viz-nav-link:hover,
	.viz-nav-link:active {
		color: rgb(255, 255, 255) !important;
	}

	@media print {
		:global(.discourse-image-block) {
			break-before: auto !important;
			page-break-before: auto !important;
			break-after: auto !important;
			page-break-after: auto !important;
			break-inside: auto !important;
			page-break-inside: auto !important;
		}

		/* Respect the global toggle: hidden means no image in print */
		.discourse-image.hidden {
			display: none !important;
		}

		/* For visible images, flatten the carousel and show all slides */
		.discourse-image:not(.hidden) {
			display: block !important;
			break-before: auto !important;
			page-break-before: auto !important;
			break-after: auto !important;
			page-break-after: auto !important;
			break-inside: auto !important;
			page-break-inside: auto !important;
		}

		.discourse-image:not(.hidden) .carousel-slide {
			display: block !important;
			opacity: 1 !important;
			break-inside: auto;
			page-break-inside: auto;
		}

		.discourse-image:not(.hidden) .image-frame {
			overflow: visible !important;
			border-radius: 0 !important;
		}

		/* Hide interactive controls that don't make sense in PDFs */
		#carouselPrev,
		#carouselNext,
		#carouselDots,
		#expandImageBtn,
		#imageModal {
			display: none !important;
		}

		/* Let images use full content width — no height cap so they stay readable */
		.discourse-image:not(.hidden) img {
			max-width: 100% !important;
			width: 100% !important;
			height: auto !important;
			break-inside: auto;
			page-break-inside: auto;
		}

		.discourse-image:not(.hidden) .svg-screen {
			display: none !important;
		}

		.discourse-image:not(.hidden) .svg-print {
			display: block !important;
			overflow: visible;
			break-inside: auto;
			page-break-inside: auto;
		}

		/* :global(svg) needed because set:html content lacks Astro scoping attributes */
		.discourse-image:not(.hidden) .svg-print :global(svg) {
			display: block;
			width: 100% !important;
			height: auto !important;
			margin: 0 auto;
		}

		/* If inline SVG markup is unavailable, render at full width */
		.discourse-image:not(.hidden) img.svg-image {
			width: 100% !important;
			height: auto !important;
			margin: 0 auto !important;
		}
	}
</style>
