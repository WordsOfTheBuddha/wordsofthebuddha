	:global(html[data-viz-image-mode="thermal"]) #discourseImageFigure img.svg-image,
	:global(html[data-viz-image-mode="thermal"]) #fullSvgObject,
	:global(html[data-viz-image-mode="print"]) #discourseImageFigure img.svg-image,
