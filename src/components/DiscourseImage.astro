			margin: 0 auto;
		}

		/* Match on-screen diagram mode when printing inline SVG (browser support varies) */
		:global(html[data-viz-image-mode="light"]) .discourse-image:not(.hidden) .svg-print :global(svg) {
			filter: var(--discourse-viz-filter-light) !important;
			-webkit-print-color-adjust: exact;
			print-color-adjust: exact;
		}
		:global(html[data-viz-image-mode="thermal"]) .discourse-image:not(.hidden) .svg-print :global(svg),
		:global(html[data-viz-image-mode="print"]) .discourse-image:not(.hidden) .svg-print :global(svg) {
			filter: var(--discourse-viz-filter-thermal) !important;
			-webkit-print-color-adjust: exact;
			print-color-adjust: exact;
		}
		:global(html[data-viz-image-mode="dark"]) .discourse-image:not(.hidden) .svg-print :global(svg) {
			filter: none !important;
		}

		/* Screen raster path: <img class="svg-image"> — same filters as on screen */
		:global(html[data-viz-image-mode="light"]) .discourse-image:not(.hidden) img.svg-image {
			filter: var(--discourse-viz-filter-light) !important;
			-webkit-print-color-adjust: exact;
			print-color-adjust: exact;
		}
		:global(html[data-viz-image-mode="thermal"]) .discourse-image:not(.hidden) img.svg-image,
		:global(html[data-viz-image-mode="print"]) .discourse-image:not(.hidden) img.svg-image {
			filter: var(--discourse-viz-filter-thermal) !important;
			-webkit-print-color-adjust: exact;
			print-color-adjust: exact;
		}
		:global(html[data-viz-image-mode="dark"]) .discourse-image:not(.hidden) img.svg-image {
			filter: none !important;
