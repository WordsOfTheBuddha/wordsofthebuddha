	}

	:global(.dark) .discourse-image img:not(.svg-image) {
		filter: brightness(0.92);
	}

	/*
	 * SVG diagram colors: data-viz-image-mode on <html> (set by inline script + switcher).
	 * light / dark follow site theme by default until user sets vizImageMode in localStorage.
	 * thermal = invert + grayscale + punch (near-white paper, strong ink for labels).
	 */
	:global(html) {
		--discourse-viz-filter-light: invert(1) hue-rotate(180deg) saturate(0.88) contrast(1.06);
		--discourse-viz-filter-thermal: invert(1) grayscale(1) contrast(1.2) brightness(1.14);
	}

	:global(html[data-viz-image-mode="light"]) #discourseImageFigure img.svg-image,
