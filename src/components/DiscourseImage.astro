	.viz-mode-trigger {
		cursor: pointer;
	}

	.carousel-slide {
		transition: opacity 0.3s ease-in-out;
	}

	.viz-nav-link,
	.viz-nav-link:visited,
	.viz-nav-link:hover,
	.viz-nav-link:active {
		text-decoration: none !important;
	}

	/* Readable on any image (overrides prose / theme link colors) */
	.viz-nav-link {
		color: rgba(255, 255, 255, 0.95) !important;
	}

	.viz-nav-link:hover,
	.viz-nav-link:active {
		color: rgb(255, 255, 255) !important;
	}

	/* Carousel dots above zoom dock (diagram mode moved to top-left) */
	#modalDots.viz-modal-dots {
		bottom: max(5.75rem, env(safe-area-inset-bottom, 0px));
	}
	@media (min-width: 640px) {
		#modalDots.viz-modal-dots {
			bottom: max(5rem, env(safe-area-inset-bottom, 0px));
		}
	}

	@media print {
		/* Do not set print-color-adjust on <html> — it forces the whole page to print like the web UI.
		   Viz filters + exact color are scoped to .discourse-image / PrintFormatter slices only. */

		:global(.discourse-image-block) {
			break-before: auto !important;
			page-break-before: auto !important;
			break-after: auto !important;
			page-break-after: auto !important;
			break-inside: auto !important;
			page-break-inside: auto !important;
		}

		/* Respect the global toggle: hidden means no image in print */
		.discourse-image.hidden {
			display: none !important;
		}

		/* For visible images, flatten the carousel and show all slides */
		.discourse-image:not(.hidden) {
			display: block !important;
			break-before: auto !important;
			page-break-before: auto !important;
			break-after: auto !important;
			page-break-after: auto !important;
			break-inside: auto !important;
			page-break-inside: auto !important;
		}

		.discourse-image:not(.hidden) .carousel-slide {
			display: block !important;
			opacity: 1 !important;
			break-inside: auto;
			page-break-inside: auto;
		}

		.discourse-image:not(.hidden) .image-frame {
			overflow: visible !important;
			border-radius: 0 !important;
		}

		/* Hide interactive controls that don't make sense in PDFs */
		#carouselPrev,
		#carouselNext,
		#carouselDots,
		#expandImageBtn,
		#imageModal {
			display: none !important;
		}

		/* Let images use full content width — no height cap so they stay readable */
		.discourse-image:not(.hidden) img {
			max-width: 100% !important;
			width: 100% !important;
			height: auto !important;
			break-inside: auto;
			page-break-inside: auto;
		}

		.discourse-image:not(.hidden) .svg-screen {
