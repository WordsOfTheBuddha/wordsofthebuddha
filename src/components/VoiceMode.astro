---
/**
 * Read-aloud voice mode: loads manifest + opus (local /audio/… or PUBLIC_AUDIO_BASE_URL)
 * when present. Toggle from toolbar; ?voice=1 opens the bar on load.
 */
interface Props {
	discourseId: string;
}
const { discourseId } = Astro.props;
---

<>
	<button
		type="button"
		id="voice-mode-trigger"
		class="voice-mode-trigger hidden"
		aria-label="Listen to this discourse"
		aria-pressed="false"
		title="Listen — voice mode (V)"
		data-discourse-id={discourseId}
	>
		<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4" aria-hidden="true">
			<path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 0 1 0 12.728M16.463 8.288a5.25 5.25 0 0 1 0 7.424M6.75 8.25l4.72-4.72a.75.75 0 0 1 1.28.53v15.88a.75.75 0 0 1-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.009 9.009 0 0 1 2.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75Z" />
		</svg>
		<span class="hidden sm:inline">Listen</span>
	</button>

	<audio id="voice-audio" preload="metadata" class="hidden" crossorigin="anonymous"></audio>

	<div id="voice-bar" class="voice-bar hidden" role="region" aria-label="Voice playback">
		<div class="voice-bar-row voice-bar-main">
			<button type="button" id="voice-prev" class="voice-nav-btn" aria-label="Previous paragraph" title="Previous paragraph">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4"><path d="M15.79 14.77a.75.75 0 0 1-1.06.02l-4.5-4.25a.75.75 0 0 1 0-1.08l4.5-4.25a.75.75 0 1 1 1.04 1.08L11.832 10l3.938 3.71a.75.75 0 0 1 .02 1.06ZM8.284 14.77a.75.75 0 0 1-1.06.02l-4.5-4.25a.75.75 0 0 1 0-1.08l4.5-4.25a.75.75 0 1 1 1.04 1.08L4.831 10l3.938 3.71a.75.75 0 0 1 .015 1.06Z" /></svg>
			</button>
			<button type="button" id="voice-play" class="voice-play-btn" aria-label="Play" title="Play">▶</button>
			<button type="button" id="voice-next" class="voice-nav-btn" aria-label="Next paragraph" title="Next paragraph">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4"><path d="M4.21 5.23a.75.75 0 0 1 1.06-.02l4.5 4.25a.75.75 0 0 1 0 1.08l-4.5 4.25a.75.75 0 0 1-1.04-1.08L8.168 10 4.23 6.29a.75.75 0 0 1-.02-1.06ZM11.716 5.23a.75.75 0 0 1 1.06-.02l4.5 4.25a.75.75 0 0 1 0 1.08l-4.5 4.25a.75.75 0 0 1-1.04-1.08L15.169 10l-3.94-3.71a.75.75 0 0 1-.014-1.06Z" /></svg>
			</button>
			<input
				id="voice-seek"
				class="voice-seek"
				type="range"
				min="0"
				max="100"
				step="0.01"
				value="0"
				aria-label="Seek"
			/>
			<span id="voice-time" class="voice-time">0:00 / 0:00</span>
			<span id="voice-segment" class="voice-time voice-segment">—</span>
		</div>
		<div class="voice-bar-row voice-bar-controls">
			<div class="voice-speed" role="group" aria-label="Playback speed">
				<button type="button" data-rate="0.75" title="0.75× speed">0.75×</button>
				<button type="button" data-rate="1" class="voice-rate-active" title="Normal speed (1×)">1×</button>
				<button type="button" data-rate="1.25" title="1.25× speed">1.25×</button>
			</div>
			<button type="button" id="voice-focus-toggle" class="voice-ctrl-btn voice-rate-active" title="Toggle focus (dim surrounding text)">Focus: On</button>
			<button type="button" id="voice-exit" class="voice-ctrl-btn voice-exit-btn" aria-label="Exit voice mode (V)" title="Close voice mode">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5"><path d="M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 1 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22Z"/></svg>
			</button>
		</div>
	</div>
</>

<script>
	import { initVoiceMode } from "../utils/voiceModeClient";

	const btn = document.getElementById("voice-mode-trigger");
	const id = btn?.dataset.discourseId;
	if (btn && id) initVoiceMode(id, btn);
</script>
