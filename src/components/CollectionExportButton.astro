---
/**
 * Opens the collection PDF export preview modal (CollectionPdfExportModal in CollectionLayout).
 */
interface Props {
	collectionSlug: string;
	label?: string;
}

const { collectionSlug, label = "Print PDF" } = Astro.props;
import { transformId } from "../utils/transformId";
---

<button
	type="button"
	class="export-btn"
	data-open-collection-pdf-modal
	aria-haspopup="dialog"
	aria-controls="collection-pdf-export-dialog"
	aria-label={`${label} for ${transformId(collectionSlug)}`}
	title={`Configure and download a PDF of ${transformId(collectionSlug)}`}
>
	<svg
		class="export-icon"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="1.5"
		stroke-linecap="round"
		stroke-linejoin="round"
		aria-hidden="true"
		xmlns="http://www.w3.org/2000/svg"
	>
		<path
			d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"
		></path>
	</svg>
	<span class="export-label">{label}</span>
</button>

<style>
	.export-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.35em;
		padding: 0.3rem 0.75rem;
		font-size: 0.8rem;
		font-family: inherit;
		color: var(--text-muted, #666);
		background: transparent;
		border: 1px solid var(--border-color, rgba(44, 44, 44, 0.2));
		border-radius: 9999px;
		cursor: pointer;
		transition:
			color 0.15s,
			border-color 0.15s,
			background 0.15s;
		white-space: nowrap;
	}

	.export-btn:hover:not(:disabled) {
		color: var(--primary-color, #6b21a8);
		border-color: var(--primary-color, #6b21a8);
		background: var(--surface-paper, #faf9f6);
	}

	.export-icon {
		width: 1em;
		height: 1em;
		flex-shrink: 0;
	}
</style>
