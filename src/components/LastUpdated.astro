---
const { lastUpdated, path, viewSource = "en" } = Astro.props as {
	lastUpdated?: string | null;
	path?: string;
	viewSource?: "en" | "sujato-reference";
};

export const formatDate = (date: string | null) => {
	if (!date) return null;
	try {
		return new Date(date).toLocaleDateString("en-US", {
			year: "numeric",
			month: "long",
			day: "numeric",
		});
	} catch {
		return null;
	}
};

const formattedDate = formatDate(lastUpdated ?? null);

const sourceHref =
	viewSource === "sujato-reference"
		? `https://github.com/wordsofthebuddha/wordsofthebuddha/tree/main/src/content/references/sujato/${path}.md`
		: `https://github.com/wordsofthebuddha/wordsofthebuddha/tree/main/src/content/en/${path}.mdx`;
---

{
	formattedDate && (
		<div class="flex justify-between items-center last-updated">
			<p class="text-sm" style="color: var(--gray-500);">
				Last updated on {formattedDate}
			</p>
			<div class="flex items-center space-x-4 ml-auto">
				<a
					href={sourceHref}
					class="ml-2 hover:underline text-sm"
					style="color: var(--gray-500)"
					target="_blank"
					rel="noopener noreferrer"
				>
					View Source ↗
				</a>
			</div>
		</div>
	)
}
