<!-- src/components/PrintFormatter.astro -->
<script>
	import { getFormattedContainer } from "../utils/tooltipFormatter";

	function setupPrintFormatting() {
		let originalContent: string | null = null;
		let originalImageParent: HTMLElement | null = null;
		let originalImageNode: Element | null = null; // actual DOM node — preserves event listeners
		let imageSliceElements: Element[] = [];

		window.addEventListener("beforeprint", () => {
			// Find the main content area (prefer the currently visible layout)
			const isSplit =
				document.documentElement.classList.contains("split") &&
				document.documentElement.classList.contains("pali-on");
			const contentArea =
				(isSplit
					? document.querySelector(".split-wrapper")
					: document.querySelector("article.prose") ||
						document.querySelector(".interleaved-article")) ||
				document.querySelector("main") ||
				document.querySelector(".prose");

			if (!contentArea) return;

			// Store original content
			originalContent = contentArea.innerHTML;

			// Create range for the content
			const range = document.createRange();
			range.selectNodeContents(contentArea);

			// Apply rich formatting (same logic as copy button)
			const formattedContainer = getFormattedContainer(range, 0, {
				includeSeparator: false,
			});
			// Print-only safeguard: remove any standalone markdown-style separator
			// immediately before a Key Terms heading.
			Array.from(formattedContainer.querySelectorAll("p")).forEach((p) => {
				const text = (p.textContent || "").trim();
				if (text !== "---") return;
				const next = p.nextElementSibling as HTMLElement | null;
				if (!next) return;
				const nextText = (next.textContent || "").trim().toLowerCase();
				if (nextText.startsWith("key terms")) {
					p.remove();
				}
			});

			// Replace content with formatted version
			contentArea.innerHTML = formattedContainer.innerHTML;
			contentArea.classList.add("print-formatted");

			// Prepare discourse images for print.
			// The figure lives in the PostLayout article as a sibling of the
			// interleaved-article (contentArea), NOT inside it.  So we must
			// search the whole document.
			// Chrome cannot split <svg>/<img> across pages, so we slice tall
			// SVGs into viewBox chunks and replace the figure in-place.
			const imageBlock = document.querySelector(
				".discourse-image-block"
			) as HTMLElement | null;
			const figure = (
				imageBlock
					? imageBlock.querySelector(".discourse-image:not(.hidden)")
					: document.querySelector(".discourse-image:not(.hidden)")
			) as HTMLElement | null;

			// Reset image state
			imageSliceElements = [];
			originalImageParent = null;
			originalImageNode = null;

			if (figure) {
				const svgPrint = figure.querySelector(".svg-print") as HTMLElement | null;
				const svg = svgPrint?.querySelector("svg");
				const insertionAnchor = (imageBlock || figure) as HTMLElement;
				// Save for afterprint restoration
				originalImageParent = insertionAnchor.parentNode as HTMLElement;
				originalImageNode = insertionAnchor; // keep the live DOM node

				// Resolve diagram color mode so sliced strips match on-screen appearance.
				// Sync from localStorage first (mirrors DiscourseImage beforeprint handler).
				let vizMode =
					document.documentElement.getAttribute("data-viz-image-mode") || "dark";
				try {
					let stored = localStorage.getItem("vizImageMode");
					if (stored === "print") { stored = "thermal"; }
					if (stored === "light" || stored === "dark" || stored === "thermal") {
						vizMode = stored;
						document.documentElement.setAttribute("data-viz-image-mode", vizMode);
					}
				} catch { /* localStorage unavailable */ }

				const FILTER_LIGHT =
					"invert(1) hue-rotate(180deg) saturate(0.88) contrast(1.06)";
				const FILTER_THERMAL =
					"invert(1) grayscale(1) contrast(1.2) brightness(1.14)";
				const vizFilter =
					vizMode === "light"
						? FILTER_LIGHT
						: vizMode === "thermal"
							? FILTER_THERMAL
							: "";
				// Gap-fill background: white when filter inverts, else original dark
				const vizBgOverride =
					vizMode === "light" || vizMode === "thermal" ? "#ffffff" : "";

				if (svg) {
					const vb = svg.getAttribute("viewBox");
					const parts = vb
						? vb.split(/[\s,]+/).map(Number)
						: [];

					if (parts.length === 4) {
						const [vbX, vbY, vbW, vbH] = parts;

						const parent = insertionAnchor.parentNode!;

						const firstStop = svg.querySelector(
							"defs linearGradient:first-of-type stop"
						);
						const bgColor = vizBgOverride
							|| firstStop?.getAttribute("stop-color")
							|| "#0b1528";

						let slices: { y: number; h: number }[] = [];
						const safeCutsAttr = svgPrint?.getAttribute("data-safe-cuts");
						if (safeCutsAttr) {
							const cuts = safeCutsAttr.split(",").map(Number);
							for (let i = 0; i < cuts.length - 1; i++) {
								slices.push({ y: cuts[i], h: cuts[i + 1] - cuts[i] });
							}
						}
						if (slices.length === 0) {
							const STRIP_H = 100;
							let curY = vbY;
							let rem = vbH;
							while (rem > 0) {
								const h = Math.min(STRIP_H, rem);
								slices.push({ y: curY, h });
								curY += h;
								rem -= h;
							}
						}

						const wrapper = document.createElement("div");
						wrapper.style.cssText =
							`background:${bgColor};line-height:0;font-size:0;-webkit-print-color-adjust:exact;print-color-adjust:exact;`;

						for (const slice of slices) {
							const clone = svg.cloneNode(true) as SVGElement;
							clone.setAttribute(
								"viewBox",
								`${vbX} ${slice.y} ${vbW} ${slice.h}`
							);
							clone.removeAttribute("width");
							clone.removeAttribute("height");
							const filterCss = vizFilter
								? `filter:${vizFilter};-webkit-print-color-adjust:exact;print-color-adjust:exact;`
								: "";
							clone.style.cssText =
								`display:block;width:100%;height:auto;max-width:100%;margin:0;padding:0;${filterCss}`;
							wrapper.appendChild(clone);
						}

						const spacer = document.createElement("div");
						spacer.style.cssText = "height:2em;";

						parent.insertBefore(wrapper, insertionAnchor);
						parent.insertBefore(spacer, insertionAnchor);
						imageSliceElements.push(wrapper, spacer);
						insertionAnchor.remove();
					}
				} else {
					// Non-SVG raster image — also apply viz filter when needed
					const img = figure.querySelector("img");
					if (img) {
						const clone = img.cloneNode(true) as HTMLImageElement;
						const filterCss = vizFilter
							? `filter:${vizFilter};-webkit-print-color-adjust:exact;print-color-adjust:exact;`
							: "";
						clone.style.cssText =
							`display:block;width:100%;height:auto;max-width:100%;max-height:600px;margin:0 0 1em;padding:0;${filterCss}`;
						insertionAnchor.parentNode!.insertBefore(
							clone,
							insertionAnchor
						);
						imageSliceElements.push(clone);
					}
					insertionAnchor.remove();
				}
			}

			// Notify that tooltip formatting is complete
			setTimeout(() => {
				const alignmentEvent = new Event("print-formatting-complete");
				window.dispatchEvent(alignmentEvent);
			}, 50);
		});

		window.addEventListener("afterprint", () => {
			// Restore original content area
			const contentArea = document.querySelector(".print-formatted");
			if (originalContent && contentArea) {
				contentArea.innerHTML = originalContent;
				contentArea.classList.remove("print-formatted");
				originalContent = null;
			}
			// Restore discourse image (it lives outside contentArea)
			if (originalImageNode && originalImageParent) {
				// Remove injected slices
				for (const el of imageSliceElements) {
					el.remove();
				}
				imageSliceElements = [];
				// Re-insert the original DOM node (preserves all event listeners)
				const interleavedArticle =
					originalImageParent.querySelector(".interleaved-article");
				if (interleavedArticle) {
					originalImageParent.insertBefore(originalImageNode, interleavedArticle);
				} else {
					originalImageParent.appendChild(originalImageNode);
				}
				originalImageParent = null;
				originalImageNode = null;
			}
		});
	}

	// Initialize
	document.addEventListener("DOMContentLoaded", setupPrintFormatting);
</script>

<style is:global>
	@media print {
		/* Hide interactive elements */
		.copy-btn,
		.bottom-popover,
		button:not(.print-keep),
		.navbar,
		nav,
		.breadcrumbs,
		.quality-tags,
		.last-updated,
		footer {
			display: none !important;
		}

		.print-formatted {
			font-family: "Times New Roman", serif;
			font-size: 12pt;
			line-height: 1.6;
			color: #000 !important;
		}

		/* Normalize all colors to black for printing */
		.print-formatted,
		.print-formatted *,
		.print-formatted :is(p, span, li, em, strong, blockquote) {
			color: #000 !important;
			opacity: 1 !important;
			-webkit-text-fill-color: #000 !important; /* Safari print */
		}

		/* Force consistent font sizing for all text elements including Pali */
		.print-formatted .pali-paragraph {
			font-size: 12pt !important;
			opacity: 1 !important;
			color: #000 !important;
		}

		.print-formatted .verse {
			color: #000 !important;
		}

		.print-formatted b {
			font-weight: bold;
		}

		/* Style footnotes section */
		.print-formatted > div:last-child {
			margin-top: 1em;
			padding-top: 1em;
			border-top: 1px solid #333;
			font-size: 11pt;
		}

		/* Ensure footnotes content also has consistent sizing */
		.print-formatted > div:last-child * {
			font-size: 11pt !important;
		}

		/* Single-page print: render Key Terms as plain lines (no bullets) */
		.print-formatted .key-terms-list {
			list-style: none !important;
			margin: 0.25em 0 0.5em 0 !important;
			padding-left: 0 !important;
		}
		.print-formatted .key-terms-list li {
			margin: 0.35em 0 !important;
		}

		/* Ensure good page breaks */
		.print-formatted h1,
		.print-formatted h2,
		.print-formatted h3 {
			page-break-after: avoid;
		}

		.print-formatted p {
			orphans: 3;
			widows: 3;
		}
	}
</style>
